{
  "name": "alumni-book-v2",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd", "sharp"]
  },
  "scripts": {
    "dev:site": "pnpm --filter site-astro dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r build",
    "build:site": "pnpm --filter site-astro build",
    "build:admin": "pnpm --filter admin build",
    "deploy:worker": "pnpm --filter worker run deploy",
    "db:migrate": "pnpm --filter worker run db:migrate",
    "migrate:data": "tsx scripts/migrate.ts",
    "migrate:chat-data": "tsx scripts/migrate-chat-data.ts",
    "audit:content": "tsx scripts/audit-content.ts",
    "verify:worker": "pnpm --filter worker exec vitest run",
    "verify:admin": "pnpm --filter admin test && pnpm --filter admin typecheck && pnpm --filter admin build",
    "verify:site": "pnpm --filter site-astro typecheck && pnpm --filter site-astro test:with-build && pnpm --filter site-astro test:perf-network",
    "verify:all": "pnpm verify:worker && pnpm verify:admin && pnpm verify:site"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
