{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --port 3001",
    "build": "vue-tsc --noEmit && vite build",
    "test": "node tests/community-static.mjs && node tests/network-integration-static.mjs && pnpm run test:network && tsx --test tests/audit-summary.test.ts",
    "test:network": "tsx --test tests/network.test.ts",
    "verify:dist-network": "node tests/dist-network.mjs",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test:static": "node tests/permissions-static.test.mjs && node tests/change-password-view-static.test.mjs"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "@alumni/shared": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  }
}
