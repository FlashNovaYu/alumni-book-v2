---
import TopNav from '../components/TopNav.astro'
import AppFooter from '../components/AppFooter.astro'
import { getSsgApiBase } from '../utils/ssgApiBase'
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'

const apiBase = import.meta.env.VITE_API_BASE_URL || ''
const buildApiBase = getSsgApiBase()
const defaultIdentity = { siteName: '同学录', className: '', classYear: '', shareDescription: '同学录 · 青春回忆' }
let siteConfig = { identity: defaultIdentity, footer: { copyright: '同学录 · 青春回忆' } }

try {
  const response = await fetch(buildApiBase + '/api/config')
  if (response.ok) {
    const payload = await response.json()
    if (payload?.data) {
      siteConfig = {
        ...siteConfig,
        ...payload.data,
        identity: { ...defaultIdentity, ...payload.data.identity },
        footer: { ...siteConfig.footer, ...payload.data.footer },
      }
    }
  }
} catch {}

const classLabel = [siteConfig.identity.className, siteConfig.identity.classYear].filter(Boolean).join(' · ')
const footerText = [classLabel, siteConfig.footer.copyright].filter(Boolean).join(' · ') || '同学录 · 青春回忆'
---

<html lang="zh-CN" data-api-base={apiBase}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteConfig.identity.siteName || '同学录'}</title>
    <meta name="description" content={siteConfig.identity.shareDescription || '同学录 · 青春回忆'} />
    <meta name="theme-color" content="#f4eddf" />
    <ClientRouter />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />
    <script is:inline>
      (() => {
        const storageKey = 'alumni_theme'
        const stored = localStorage.getItem(storageKey)
        const theme = stored === 'paper' || stored === 'night'
          ? stored
          : matchMedia('(prefers-color-scheme: dark)').matches ? 'night' : 'paper'
        document.documentElement.dataset.theme = theme
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', theme === 'night' ? '#20252d' : '#f4eddf')
      })()
    </script>
    <script is:inline define:vars={{ apiBase }}>
      (async function () {
        document.documentElement.classList.add('js')
        const path = window.location.pathname
        const isHome = path === '/' || path.endsWith('/index.html') || path.endsWith('/alumni-book-v2/')
        const isExempt = isHome || path.includes('/admin/') || path.includes('/404')
        const classmateToken = sessionStorage.getItem('classmate_account_token')

        try {
          const student = JSON.parse(sessionStorage.getItem('classmate_account_student') || 'null')
          const adminEntry = JSON.parse(sessionStorage.getItem('alumni_nav_admin_entry') || 'null')
          if (classmateToken && student?.slug && adminEntry?.studentSlug === student.slug && adminEntry.available === true) {
            document.documentElement.classList.add('has-admin-entry')
          }
        } catch {}

        if (!isExempt && !classmateToken) {
          const adminToken = sessionStorage.getItem('admin_token')
          if (adminToken) {
            try {
              const response = await fetch(apiBase + '/api/auth/verify', {
                headers: { Authorization: 'Bearer ' + adminToken },
              })
              if (response.ok) return
            } catch {}
          }
          window.location.replace(path.includes('/alumni-book-v2/') ? '/alumni-book-v2/' : '/')
        }
      })()

      function syncSiteIdentity() {
        fetch(apiBase + '/api/config')
          .then((response) => response.ok ? response.json() : null)
          .then((payload) => {
            const config = payload?.data
            const identity = config?.identity
            if (!identity) return
            if (identity.siteName) document.title = identity.siteName
            const description = document.querySelector('meta[name="description"]')
            if (description && identity.shareDescription) description.setAttribute('content', identity.shareDescription)
            const footer = document.querySelector('[data-site-footer]')
            if (footer) {
              const classLabel = [identity.className, identity.classYear].filter(Boolean).join(' · ')
              footer.textContent = [classLabel, config.footer?.copyright].filter(Boolean).join(' · ') || '同学录 · 青春回忆'
            }
          })
          .catch(() => undefined)
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', syncSiteIdentity, { once: true })
      else syncSiteIdentity()
    </script>
  </head>
  <body>
    <!-- 动态呼吸光晕渐变背景与回忆之尘 -->
    <div class="alumni-ambient-bg" aria-hidden="true">
      <div class="alumni-fluid alumni-fluid-1"></div>
      <div class="alumni-fluid alumni-fluid-2"></div>
      <div class="alumni-fluid alumni-fluid-3"></div>
      <div class="alumni-dust alumni-dust-1"></div>
      <div class="alumni-dust alumni-dust-2"></div>
    </div>
    <div class="app">
      <TopNav />
      <main class="main-content"><slot /></main>
      <script>
        let reinitAuxiliaryRuntime = () => {}

        function restoreStudentIdentityTarget() {
          const path = window.location.pathname
          if (!path.includes('/roster/')) return
          let slug = sessionStorage.getItem('vt-student-return-slug') || ''
          try {
            const state = JSON.parse(sessionStorage.getItem('vt-student-identity-state') || 'null') as { slug?: unknown } | null
            if (typeof state?.slug === 'string') slug = state.slug
          } catch {}
          if (!slug) return
          const apply = () => {
            const card = Array.from(document.querySelectorAll<HTMLElement>('[data-student-identity-card]'))
              .find((element) => element.dataset.studentIdentityCard === slug)
            if (!card) return false
            const avatar = card?.querySelector<HTMLElement>('.roster-card__avatar, .archive-card__avatar')
            const name = card?.querySelector<HTMLElement>('.roster-card__name, .archive-card__name')
            const details = card?.querySelector<HTMLElement>('[data-student-card-details]')
            avatar?.style.setProperty('view-transition-name', `student-avatar-${slug}`)
            avatar?.style.setProperty('view-transition-class', 'student-identity')
            name?.style.setProperty('view-transition-name', `student-name-${slug}`)
            name?.style.setProperty('view-transition-class', 'student-identity')
            details?.style.setProperty('view-transition-name', `student-card-details-${slug}`)
            details?.style.setProperty('view-transition-class', 'student-card-details')
            return true
          }
          let observer: MutationObserver | null = null
          let attempts = 0
          const tryApply = () => {
            const applied = apply()
            if (applied) {
              observer?.disconnect()
              sessionStorage.removeItem('vt-student-return-slug')
              sessionStorage.removeItem('vt-student-identity-state')
            }
            return applied
          }
          const retry = () => {
            if (tryApply() || attempts++ >= 60) return
            requestAnimationFrame(retry)
          }
          if (!tryApply()) {
            observer = new MutationObserver(tryApply)
            observer.observe(document.body, { childList: true, subtree: true })
            retry()
            window.setTimeout(() => {
              observer?.disconnect()
              sessionStorage.removeItem('vt-student-return-slug')
              sessionStorage.removeItem('vt-student-identity-state')
            }, 3000)
          }
        }

        restoreStudentIdentityTarget()
        void Promise.all([
          import('../scripts/navRuntime'),
          import('../scripts/globalReveal'),
          import('../scripts/themeRuntime'),
          import('../runtime/navSession'),
          import('../runtime/volumeToggle'),
        ]).then(([navRuntime, globalReveal, themeRuntime, navSession, volumeToggle]) => {
          const apiBase = document.documentElement.dataset.apiBase || ''
          reinitAuxiliaryRuntime = () => {
            navRuntime.initNavRuntime()
            globalReveal.initGlobalReveal(true)
            themeRuntime.initThemeRuntime()
            navSession.initNavSession(apiBase)
            volumeToggle.initVolumeToggle()
          }
          reinitAuxiliaryRuntime()
        })

        const order = ['/', '/preface/', '/roster/', '/class-space/', '/yearbook/', '/more/']
        const cleanPath = (path: string) => {
          const clean = path.replace(/\/index\.html$/, '/')
          return clean.endsWith('/') ? clean : clean + '/'
        }
        const setNavigationState = (target: string, click?: MouseEvent) => {
          const from = cleanPath(window.location.pathname)
          const to = cleanPath(new URL(target, window.location.href).pathname)
          const fromIndex = order.indexOf(from)
          const toIndex = order.indexOf(to)
          if (fromIndex !== -1 && toIndex !== -1 && from !== to) {
            const direction = toIndex > fromIndex ? 'forward' : 'back'
            document.documentElement.dataset.navDir = direction
            sessionStorage.setItem('vt-nav-dir', direction)
          }
          if (to.includes('/mailbox/')) {
            document.documentElement.classList.add('vt-mailbox')
            if (click) {
              sessionStorage.setItem('vt-click-x', String(click.clientX))
              sessionStorage.setItem('vt-click-y', String(click.clientY))
            }
          }
          document.documentElement.classList.add('is-navigating')
        }

        let navigationResetTimer: ReturnType<typeof setTimeout> | null = null
        const clearNavigationState = () => {
          document.documentElement.classList.remove('is-navigating')
          if (navigationResetTimer !== null) clearTimeout(navigationResetTimer)
          navigationResetTimer = null
        }

        const clearStudentTransition = () => {
          document.documentElement.removeAttribute('data-student-transition')
          for (const property of ['--student-card-left', '--student-card-top', '--student-card-right', '--student-card-bottom']) {
            document.documentElement.style.removeProperty(property)
          }
          sessionStorage.removeItem('vt-student-edge-state')
        }

        function prepareStudentTransition(card: HTMLElement, slug: string) {
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || typeof document.startViewTransition !== 'function') return false
          const rect = card.getBoundingClientRect()
          const geometry = {
            left: `${rect.left}px`,
            top: `${rect.top}px`,
            right: `${innerWidth - rect.right}px`,
            bottom: `${innerHeight - rect.bottom}px`,
          }
          document.documentElement.dataset.studentTransition = 'edge'
          document.documentElement.style.setProperty('--student-card-left', geometry.left)
          document.documentElement.style.setProperty('--student-card-top', geometry.top)
          document.documentElement.style.setProperty('--student-card-right', geometry.right)
          document.documentElement.style.setProperty('--student-card-bottom', geometry.bottom)
          sessionStorage.setItem('vt-student-edge-state', JSON.stringify({ slug, ...geometry }))

          const avatar = card.querySelector<HTMLElement>('.roster-card__avatar, .archive-card__avatar')
          const name = card.querySelector<HTMLElement>('.roster-card__name, .archive-card__name')
          const details = card.querySelector<HTMLElement>('[data-student-card-details]')
          avatar?.style.setProperty('view-transition-name', `student-avatar-${slug}`)
          avatar?.style.setProperty('view-transition-class', 'student-identity')
          name?.style.setProperty('view-transition-name', `student-name-${slug}`)
          name?.style.setProperty('view-transition-class', 'student-identity')
          details?.style.setProperty('view-transition-name', `student-card-details-${slug}`)
          details?.style.setProperty('view-transition-class', 'student-card-details')
          return true
        }

        document.addEventListener('astro:before-preparation', (event) => {
          const transitionEvent = event as Event & { to?: URL; sourceElement?: Element | null }
          const targetPath = new URL(transitionEvent.to || window.location.href).pathname
          const sourceCard = transitionEvent.sourceElement?.closest<HTMLElement>('[data-student-identity-card]')
          const slug = sourceCard?.dataset.studentIdentityCard
          if (targetPath.includes('/student/') && sourceCard && slug) {
            prepareStudentTransition(sourceCard, slug)
          } else if (!targetPath.includes('/student/')) {
            clearStudentTransition()
          }
        })

        document.addEventListener('astro:before-swap', (event) => {
          const nextDocument = (event as Event & { newDocument?: Document }).newDocument
          if (!nextDocument) return
          const navDirection = document.documentElement.dataset.navDir || sessionStorage.getItem('vt-nav-dir')
          if (navDirection) nextDocument.documentElement.dataset.navDir = navDirection
          let edgeState: { slug?: string; left?: string; top?: string; right?: string; bottom?: string } | null = null
          try {
            edgeState = JSON.parse(sessionStorage.getItem('vt-student-edge-state') || 'null')
          } catch {}
          const active = document.documentElement.dataset.studentTransition === 'edge' || Boolean(edgeState)
          if (!active) return
          nextDocument.documentElement.dataset.studentTransition = 'edge'
          for (const property of ['--student-card-left', '--student-card-top', '--student-card-right', '--student-card-bottom']) {
            const value = document.documentElement.style.getPropertyValue(property)
            const fallback = property === '--student-card-left' ? edgeState?.left
              : property === '--student-card-top' ? edgeState?.top
                : property === '--student-card-right' ? edgeState?.right
                  : edgeState?.bottom
            if (value || fallback) nextDocument.documentElement.style.setProperty(property, value || fallback || '')
          }
        })

        const onDocumentClick = (event: MouseEvent) => {
          if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return
          const anchor = (event.target as HTMLElement).closest<HTMLAnchorElement>('a[href]')
          if (!anchor || anchor.target === '_blank' || anchor.hasAttribute('download')) return
          const url = new URL(anchor.href, window.location.href)
          if (url.origin !== window.location.origin) return
          if (url.pathname === window.location.pathname && url.search === window.location.search) return
          const identityCard = anchor.closest<HTMLElement>('[data-student-identity-card]')
          if (identityCard?.dataset.studentIdentityCard && url.pathname.includes('/student/')) {
            const slug = identityCard.dataset.studentIdentityCard
            sessionStorage.setItem('vt-student-return-slug', slug)
            prepareStudentTransition(identityCard, slug)
          } else {
            clearStudentTransition()
          }
          setNavigationState(url.href, event)
          navigationResetTimer = setTimeout(clearNavigationState, 4000)
        }
        document.addEventListener('click', onDocumentClick, { capture: true, passive: true })
        document.addEventListener('astro:page-load', () => {
          restoreStudentIdentityTarget()
          reinitAuxiliaryRuntime()
          window.setTimeout(clearStudentTransition, 820)
        })
        window.addEventListener('pageshow', (event) => {
          clearNavigationState()
          clearStudentTransition()
          if ((event as PageTransitionEvent).persisted) {
            restoreStudentIdentityTarget()
            reinitAuxiliaryRuntime()
          }
          const direction = sessionStorage.getItem('vt-nav-dir')
          if (direction) document.documentElement.dataset.navDir = direction
          sessionStorage.removeItem('vt-nav-dir')
          const x = Number(sessionStorage.getItem('vt-click-x'))
          const y = Number(sessionStorage.getItem('vt-click-y'))
          if (x && y && document.documentElement.classList.contains('vt-mailbox') && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
            const radius = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y))
            document.documentElement.animate({ clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${radius}px at ${x}px ${y}px)`] }, { duration: 420, easing: 'cubic-bezier(0.22, 1, 0.36, 1)' })
          }
          sessionStorage.removeItem('vt-click-x')
          sessionStorage.removeItem('vt-click-y')
          document.documentElement.classList.remove('vt-mailbox')
        })
        window.addEventListener('pagehide', (event) => {
          if ((event as PageTransitionEvent).persisted) return
          document.removeEventListener('click', onDocumentClick, true)
          window.__alumniNavRuntime?.destroy()
          window.__alumniThemeRuntime?.destroy()
          window.__alumniVolumeRuntime?.destroy()
        })

        // 自定义复古光标初始化逻辑 (无延迟跟手方案)
        function initCustomCursor() {
          if (window.matchMedia('(pointer: coarse)').matches) return;
          if (document.querySelector('.custom-cursor')) return;

          const cursor = document.createElement('div');
          cursor.className = 'custom-cursor';
          cursor.setAttribute('data-cursor', '');
          document.body.appendChild(cursor);
          document.documentElement.setAttribute('data-custom-cursor', 'true');

          let currentX = window.innerWidth / 2;
          let currentY = window.innerHeight / 2;
          let isVisible = false;

          const TEXT_SELECTOR = 'p, span, strong, em, blockquote, li, h1, h2, h3, h4, h5, h6, figcaption, td, th, label, .email-text';
          const CLICKABLE_SELECTOR = 'a, button, [role="button"], .btn, .archive-card, input, textarea, select, .profile-mail-actions a, [data-mailbox-trigger], .cursor-pointer';

          const renderCursor = () => {
            cursor.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) translate(-50%, -50%)`;
          };

          const onPointerMove = (e: PointerEvent) => {
            if (e.pointerType && e.pointerType !== 'mouse') return;
            currentX = e.clientX;
            currentY = e.clientY;
            
            if (!isVisible) {
              cursor.classList.add('is-visible');
              isVisible = true;
            }
            
            renderCursor();

            const target = e.target as HTMLElement;
            if (target && target.closest(CLICKABLE_SELECTOR)) {
              cursor.classList.add('is-clickable');
              cursor.classList.remove('is-text');
            } else if (target && target.closest(TEXT_SELECTOR)) {
              cursor.classList.add('is-text');
              cursor.classList.remove('is-clickable');
            } else {
              cursor.classList.remove('is-clickable', 'is-text');
            }
          };

          const onPointerDown = (e: PointerEvent) => {
            if (e.pointerType && e.pointerType !== 'mouse') return;
            cursor.classList.add('is-pressed');
          };

          const onPointerUp = (e: PointerEvent) => {
            if (e.pointerType && e.pointerType !== 'mouse') return;
            cursor.classList.remove('is-pressed');
          };

          const onPointerLeave = () => {
            cursor.classList.remove('is-visible');
            isVisible = false;
          };

          const cleanupCursor = () => {
            document.removeEventListener('pointermove', onPointerMove);
            document.removeEventListener('pointerdown', onPointerDown);
            document.removeEventListener('pointerup', onPointerUp);
            document.removeEventListener('pointerleave', onPointerLeave);
            cursor.remove();
            document.documentElement.removeAttribute('data-custom-cursor');
          };

          document.addEventListener('pointermove', onPointerMove, { passive: true });
          document.addEventListener('pointerdown', onPointerDown, { passive: true });
          document.addEventListener('pointerup', onPointerUp, { passive: true });
          document.addEventListener('pointerleave', onPointerLeave);
          window.addEventListener('pagehide', (event) => {
            if (!(event as PageTransitionEvent).persisted) cleanupCursor()
          });
        }
        initCustomCursor()

        // Native cross-document navigation is intentionally handled above.
      </script>
      <AppFooter initialText={footerText} />
    </div>
  </body>
</html>

<style is:global>
  .app { min-height: 100vh; display: flex; flex-direction: column; }
  .main-content { flex: 1; }

  /* Ambient Fluid Background */
  .alumni-ambient-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    background: transparent;
  }

  .alumni-fluid {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
    animation: fluidBreathing 20s infinite alternate ease-in-out;
    will-change: transform;
  }

  .alumni-fluid-1 {
    width: 45vw;
    height: 45vw;
    background: rgba(200, 169, 106, 0.12);
    top: -10vw;
    left: -10vw;
    animation-duration: 24s;
  }

  .alumni-fluid-2 {
    width: 55vw;
    height: 55vw;
    background: rgba(188, 79, 60, 0.08);
    bottom: -20vw;
    right: -10vw;
    animation-duration: 28s;
    animation-direction: alternate-reverse;
  }

  .alumni-fluid-3 {
    width: 35vw;
    height: 35vw;
    background: rgba(255, 250, 242, 0.04);
    top: 35%;
    left: 45%;
    animation-duration: 32s;
  }

  @keyframes fluidBreathing {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(4vw, 6vh) scale(1.05); }
    66% { transform: translate(-3vw, 5vh) scale(0.95); }
    100% { transform: translate(2vw, -4vh) scale(1.1); }
  }

  /* Dust Particles */
  .alumni-dust {
    position: absolute;
    inset: -100px;
    opacity: calc(0.6 * var(--starfield-opacity, 0));
    mix-blend-mode: screen;
  }

  [data-theme="paper"] .alumni-dust {
    mix-blend-mode: multiply;
    opacity: calc(0.3 * var(--starfield-opacity, 0));
  }

  .alumni-dust::before,
  .alumni-dust::after {
    content: "";
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: transparent;
    will-change: transform;
  }

  .alumni-dust-1::before {
    box-shadow:
      10vw 15vh 1px rgba(200, 169, 106, 0.5),
      25vw 80vh 2px rgba(200, 169, 106, 0.3),
      40vw 30vh 1px rgba(255, 255, 255, 0.4),
      60vw 10vh 2px rgba(200, 169, 106, 0.2),
      75vw 60vh 1px rgba(255, 255, 255, 0.5),
      90vw 40vh 2px rgba(200, 169, 106, 0.4);
    animation: dustDrift 45s linear infinite;
  }

  .alumni-dust-1::after {
    box-shadow:
      15vw 60vh 2px rgba(255, 255, 255, 0.3),
      35vw 20vh 1px rgba(200, 169, 106, 0.5),
      50vw 85vh 2px rgba(255, 255, 255, 0.4),
      70vw 25vh 1px rgba(200, 169, 106, 0.3),
      85vw 75vh 2px rgba(255, 255, 255, 0.2),
      95vw 15vh 1px rgba(200, 169, 106, 0.4);
    animation: dustDrift 55s linear infinite;
    animation-delay: -15s;
  }

  .alumni-dust-2::before {
    box-shadow:
      5vw 45vh 1px rgba(188, 79, 60, 0.3),
      30vw 90vh 2px rgba(255, 255, 255, 0.2),
      45vw 50vh 1px rgba(188, 79, 60, 0.4),
      65vw 80vh 2px rgba(255, 255, 255, 0.3),
      80vw 10vh 1px rgba(188, 79, 60, 0.2),
      98vw 55vh 2px rgba(255, 255, 255, 0.4);
    animation: dustDrift 65s linear infinite;
    animation-delay: -25s;
  }

  .alumni-dust-2::after {
    box-shadow:
      20vw 10vh 2px rgba(255, 255, 255, 0.3),
      40vw 70vh 1px rgba(188, 79, 60, 0.2),
      55vw 35vh 2px rgba(255, 255, 255, 0.4),
      75vw 95vh 1px rgba(188, 79, 60, 0.3),
      88vw 30vh 2px rgba(255, 255, 255, 0.2),
      10vw 85vh 1px rgba(188, 79, 60, 0.4);
    animation: dustDrift 75s linear infinite;
    animation-delay: -35s;
  }

  [data-theme="paper"] .alumni-dust-1::before {
    box-shadow:
      10vw 15vh 1px rgba(139, 69, 19, 0.15),
      25vw 80vh 2px rgba(100, 50, 10, 0.1),
      40vw 30vh 1px rgba(0, 0, 0, 0.08),
      60vw 10vh 2px rgba(139, 69, 19, 0.1),
      75vw 60vh 1px rgba(0, 0, 0, 0.12),
      90vw 40vh 2px rgba(139, 69, 19, 0.15);
  }

  [data-theme="paper"] .alumni-dust-1::after {
    box-shadow:
      15vw 60vh 2px rgba(0, 0, 0, 0.08),
      35vw 20vh 1px rgba(139, 69, 19, 0.15),
      50vw 85vh 2px rgba(0, 0, 0, 0.1),
      70vw 25vh 1px rgba(139, 69, 19, 0.1),
      85vw 75vh 2px rgba(0, 0, 0, 0.05),
      95vw 15vh 1px rgba(139, 69, 19, 0.12);
  }

  [data-theme="paper"] .alumni-dust-2::before {
    box-shadow:
      5vw 45vh 1px rgba(100, 30, 20, 0.1),
      30vw 90vh 2px rgba(0, 0, 0, 0.06),
      45vw 50vh 1px rgba(100, 30, 20, 0.15),
      65vw 80vh 2px rgba(0, 0, 0, 0.08),
      80vw 10vh 1px rgba(100, 30, 20, 0.08),
      98vw 55vh 2px rgba(0, 0, 0, 0.1);
  }

  [data-theme="paper"] .alumni-dust-2::after {
    box-shadow:
      20vw 10vh 2px rgba(0, 0, 0, 0.08),
      40vw 70vh 1px rgba(100, 30, 20, 0.06),
      55vw 35vh 2px rgba(0, 0, 0, 0.1),
      75vw 95vh 1px rgba(100, 30, 20, 0.1),
      88vw 30vh 2px rgba(0, 0, 0, 0.06),
      10vw 85vh 1px rgba(100, 30, 20, 0.12);
