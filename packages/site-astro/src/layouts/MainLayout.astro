---
import TopNav from '../components/TopNav.astro'
import AppFooter from '../components/AppFooter.astro'
import { ClientRouter } from 'astro:transitions' // 引入 Astro 5 视图过渡引擎
// 全局样式与轻量 reveal 动效；页面级重动画必须按需加载
import '../styles/global.css'
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>同学录</title>
    <ClientRouter /> <!-- 挂载视图过渡，接管 SPA 式局部渲染 -->
    <script is:inline>
      (function() {
        document.documentElement.classList.add('js');
        const token = sessionStorage.getItem('classmate_account_token');
        const path = window.location.pathname;
        const isHome = path === '/' || path.endsWith('/index.html') || path.endsWith('/alumni-book-v2/');
        const isAdmin = path.includes('/admin/');
        const is404 = path.includes('/404');
        if (!token && !isHome && !isAdmin && !is404) {
          const base = path.includes('/alumni-book-v2/') ? '/alumni-book-v2/' : '/';
          window.location.href = base;
        }
      })();
    </script>
    <!-- 采用本地/系统默认字体 Fallback，消除远程字体阻塞 -->
  </head>
  <body>
    <div class="app">
      <TopNav />
      <main class="main-content">
        <slot />
      </main>
      <script>
        import { initGlobalReveal } from '../scripts/globalReveal'

        // 监听视图过渡完成事件，每次进入新页面自动初始化全局 Reveal 动效
        document.addEventListener('astro:page-load', () => {
          initGlobalReveal(true)
        })
      </script>
      <AppFooter />
    </div>
  </body>
</html>

<style is:global>
  .app { min-height: 100vh; display: flex; flex-direction: column; }
  .main-content { flex: 1; }
</style>
