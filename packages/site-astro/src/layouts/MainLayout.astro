---
import TopNav from '../components/TopNav.astro'
import AppFooter from '../components/AppFooter.astro'
// GSAP 动画系统 — 见 scripts/animations.ts
import '../styles/global.css'
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>同学录</title>
    <script is:inline>
      (function() {
        const name = sessionStorage.getItem('classmate_name');
        const path = window.location.pathname;
        const isHome = path === '/' || path.endsWith('/index.html') || path.endsWith('/alumni-book-v2/');
        const isAdmin = path.includes('/admin/');
        const is404 = path.includes('/404');
        if (!name && !isHome && !isAdmin && !is404) {
          const base = path.includes('/alumni-book-v2/') ? '/alumni-book-v2/' : '/';
          window.location.href = base;
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="app">
      <TopNav />
      <main class="main-content">
        <slot />
      </main>
      <script>
        import('../scripts/animations').then(m => m.initAnimations())
      </script>
      <AppFooter />
    </div>
  </body>
</html>

<style is:global>
  .app { min-height: 100vh; display: flex; flex-direction: column; }
  .main-content { flex: 1; }
</style>
