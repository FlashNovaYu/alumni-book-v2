---
import VisitorPass from './VisitorPass.vue'

interface Props {
  apiBase: string
  heroEyebrow: string
  heroTitle: string
  heroSubtitle: string
}

const { apiBase, heroEyebrow, heroTitle, heroSubtitle } = Astro.props
---

<section class="home-cover" aria-labelledby="museum-hero-title">
  <div class="home-cover__ambient" aria-hidden="true">
    <span class="home-cover__shape home-cover__paper home-cover__paper--one"></span>
    <span class="home-cover__shape home-cover__paper home-cover__paper--two"></span>
    <span class="home-cover__shape home-cover__paper home-cover__paper--three"></span>
    <span class="home-cover__shape home-cover__film"></span>
    <span class="home-cover__shape home-cover__ghost">CLASS MEMORY</span>
  </div>

  <div class="home-cover__copy container">
    <p class="home-cover__kicker home-cover__copy-reveal" style="--reveal-delay: 0.28s">{heroEyebrow}</p>
    <h1 id="museum-hero-title" class="home-cover__title">
      <span class="home-cover__copy-reveal" style="--reveal-delay: 0.46s">{heroTitle}</span>
      <span class="home-cover__copy-reveal" style="--reveal-delay: 0.62s">翻开青春</span>
    </h1>
    <p class="home-cover__subtitle home-cover__copy-reveal" style="--reveal-delay: 0.84s">{heroSubtitle}</p>
  </div>

  <div class="home-cover__scroll-slot">
    <div class="home-cover__scroll-reveal home-cover__copy-reveal" style="--reveal-delay: 1.08s">
      <a href="#login" class="home-cover__scroll" data-home-login-scroll aria-label="向下滑动到登录入口">
        <span>向下滑动</span>
      </a>
    </div>
  </div>
</section>

<section class="home-login-cta" aria-label="进入登录">
  <a href="#login" class="home-login-cta__button home-scroll-reveal" data-testid="home-login-cta" data-home-login-scroll>
    翻开同学录，进入登录
  </a>
</section>

<section id="login" class="home-login-section" aria-labelledby="home-login-title">
  <div class="home-login-section__inner container">
    <div class="home-login-section__copy home-scroll-reveal">
      <p class="paper-kicker">CLASSMATE PASS</p>
      <h2 id="home-login-title" class="display-sm">身份验证</h2>
      <p>输入自己的同学账号与密码。首次登录后，系统会引导你把初始密码换成专属密码。</p>
    </div>
    <div class="home-login-section__pass home-scroll-reveal">
      <VisitorPass client:load apiBase={apiBase} />
    </div>
  </div>
</section>

<style>
.home-cover {
  position: relative;
  min-height: 100svh;
  display: grid;
  place-items: center;
  overflow: hidden;
  padding: calc(var(--nav-height) + var(--spacing-xl)) 0 var(--spacing-xxl);
  background:
    linear-gradient(180deg, rgba(15, 13, 11, 0.08), rgba(15, 13, 11, 0.88)),
    radial-gradient(circle at 18% 28%, rgba(200, 169, 106, 0.18), transparent 32%),
    radial-gradient(circle at 78% 72%, rgba(188, 79, 60, 0.16), transparent 34%),
    #11100e;
  color: var(--color-on-dark);
}

.home-cover__ambient {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.home-cover__shape {
  --shape-x: 0px;
  --shape-y: 0px;
  --shape-rotate: 0deg;
  --shape-drift: 15px;
  --shape-enter-delay: 0s;
  opacity: 0;
  transform: translate3d(var(--shape-x), calc(var(--shape-y) - 150px), 0) rotate(calc(var(--shape-rotate) - 15deg));
  animation:
    homeShapeEnter 2.2s cubic-bezier(0.23, 0.86, 0.39, 0.96) var(--shape-enter-delay) forwards,
    homeShapeFloat 12s ease-in-out calc(var(--shape-enter-delay) + 2.1s) infinite;
  animation-delay: var(--shape-enter-delay), calc(var(--shape-enter-delay) + 2.1s);
  will-change: transform, opacity;
}

.home-cover__paper {
  position: absolute;
  height: 54px;
  width: 260px;
  border-radius: var(--rounded-pill);
  border: 1px solid rgba(251, 246, 236, 0.12);
  background: rgba(251, 246, 236, 0.04);
}

.home-cover__paper--one {
  left: -42px;
  top: 20%;
  width: 360px;
  --shape-rotate: -13deg;
  --shape-drift: 16px;
  --shape-enter-delay: 0.18s;
}

.home-cover__paper--two {
  right: 12%;
  top: 16%;
  --shape-rotate: 19deg;
  --shape-drift: 13px;
  --shape-enter-delay: 0.34s;
  background: rgba(200, 169, 106, 0.07);
}

.home-cover__paper--three {
  right: -58px;
  bottom: 18%;
  width: 320px;
  --shape-rotate: -16deg;
  --shape-drift: 18px;
  --shape-enter-delay: 0.46s;
  background: rgba(188, 79, 60, 0.06);
}

.home-cover__film {
  position: absolute;
  left: 7%;
  bottom: 12%;
  width: 190px;
  height: 44px;
  border-radius: var(--rounded-md);
  border: 1px solid rgba(251, 246, 236, 0.11);
  background:
    repeating-linear-gradient(90deg, rgba(251, 246, 236, 0.08) 0 10px, transparent 10px 20px),
    rgba(251, 246, 236, 0.025);
  --shape-rotate: -8deg;
  --shape-drift: 10px;
  --shape-enter-delay: 0.58s;
}

.home-cover__ghost {
  position: absolute;
  left: 50%;
  top: 52%;
  --shape-x: -50%;
  --shape-y: -50%;
  --shape-rotate: 0deg;
  --shape-drift: 8px;
  --shape-enter-delay: 0.72s;
  color: rgba(255, 255, 255, 0.035);
  font-family: var(--font-display);
  font-size: clamp(58px, 11vw, 128px);
  font-weight: 700;
  white-space: nowrap;
}

.home-cover__copy {
  position: relative;
  z-index: 1;
  max-width: 920px;
  text-align: center;
}

.home-cover__kicker {
  margin-bottom: var(--spacing-lg);
  color: var(--color-paper-gold);
  font-size: var(--type-caption-uppercase-size);
  font-weight: var(--type-caption-uppercase-weight);
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.home-cover__title {
  display: grid;
  gap: var(--spacing-xs);
  margin: 0;
  color: #fffaf2;
  font-family: var(--font-display);
  font-size: clamp(52px, 9vw, 104px);
  font-weight: 500;
  line-height: 0.98;
  letter-spacing: 0;
  text-shadow: 0 16px 48px rgba(0, 0, 0, 0.35);
}

.home-cover__copy-reveal {
  --reveal-delay: 0s;
  opacity: 0;
  transform: translateY(30px);
  animation: homeCopyReveal 1s cubic-bezier(0.25, 0.4, 0.25, 1) forwards;
  animation-delay: var(--reveal-delay);
}

.home-cover__subtitle {
  max-width: 680px;
  margin: var(--spacing-xl) auto 0;
  color: rgba(255, 250, 242, 0.78);
  font-size: clamp(16px, 1.6vw, 20px);
  line-height: 1.85;
}

.home-cover__scroll-slot {
  position: absolute;
  left: 50%;
  bottom: var(--spacing-xl);
  z-index: 2;
  transform: translateX(-50%);
}

.home-cover__scroll-reveal { display: inline-block; }

.home-cover__scroll {
  display: inline-flex;
  min-height: 38px;
  align-items: center;
  justify-content: center;
  padding: 0 var(--spacing-lg);
  border: 1px solid rgba(255, 250, 242, 0.22);
  border-radius: var(--rounded-pill);
  color: rgba(255, 250, 242, 0.76);
  font-size: var(--type-body-sm-size);
  text-decoration: none;
  transition:
    border-color var(--duration-fast) var(--ease-out-quart),
    color var(--duration-fast) var(--ease-out-quart),
    transform var(--duration-fast) var(--ease-out-quart);
}

.home-cover__scroll:hover {
  color: #fffaf2;
  border-color: rgba(255, 250, 242, 0.46);
  transform: translateY(-2px);
}

.home-login-cta {
  position: relative;
  display: grid;
  place-items: center;
  min-height: 36vh;
  padding: var(--spacing-section) var(--spacing-lg);
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 250, 242, 0.28), transparent 34%),
    linear-gradient(180deg, #11100e 0%, #211d17 24%, var(--color-paper-bg) 78%);
}

.home-login-cta__button {
  display: inline-flex;
  min-height: 52px;
  align-items: center;
  justify-content: center;
  padding: 0 var(--spacing-xl);
  border: 1px solid rgba(255, 250, 242, 0.22);
  border-radius: var(--rounded-pill);
  background: var(--color-paper-card);
  color: var(--color-paper-ink);
  box-shadow: var(--shadow-paper-panel);
  font-weight: 600;
  text-decoration: none;
  transition:
    background-color var(--duration-fast) var(--ease-out-quart),
    box-shadow var(--duration-fast) var(--ease-out-quart),
    transform var(--duration-fast) var(--ease-out-quart);
}

.home-login-cta__button:hover {
  background: var(--color-paper-bg-soft);
  box-shadow: 0 16px 40px rgba(76, 59, 38, 0.14);
  transform: translateY(-2px);
}

.home-login-section {
  min-height: 100svh;
  display: grid;
  align-items: center;
  padding: calc(var(--nav-height) + var(--spacing-xl)) 0 var(--spacing-section);
  background:
    var(--texture-paper-fiber),
    var(--color-paper-bg);
  background-size: 100% 100%, 100% 26px;
  scroll-margin-top: var(--nav-height);
}

.home-login-section__inner {
  display: grid;
  grid-template-columns: minmax(0, 0.86fr) minmax(320px, 460px);
  gap: var(--spacing-xxl);
  align-items: center;
}

.home-login-section__copy {
  max-width: 520px;
  color: var(--color-paper-ink);
}

.home-login-section__copy h2 {
  margin: var(--spacing-sm) 0 var(--spacing-md);
  color: var(--color-paper-ink);
}

.home-login-section__copy p:not(.paper-kicker) {
  color: var(--color-paper-muted);
  line-height: 1.9;
}

.home-scroll-reveal {
  opacity: 1;
  transform: translateY(0) scale(1);
}

@keyframes homeScrollReveal {
  from {
    opacity: 0;
    transform: translateY(48px) scale(0.98);
    filter: blur(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes homeShapeEnter {
  0% {
    opacity: 0;
    transform: translate3d(var(--shape-x), calc(var(--shape-y) - 150px), 0) rotate(calc(var(--shape-rotate) - 15deg));
  }
  54% {
    opacity: 1;
  }
  100% {
    opacity: 1;
    transform: translate3d(var(--shape-x), var(--shape-y), 0) rotate(var(--shape-rotate));
  }
}

@keyframes homeShapeFloat {
  0%,
  100% {
    transform: translate3d(var(--shape-x), var(--shape-y), 0) rotate(var(--shape-rotate));
  }
  50% {
    transform: translate3d(var(--shape-x), calc(var(--shape-y) + var(--shape-drift)), 0) rotate(var(--shape-rotate));
  }
}

@keyframes homeCopyReveal {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@supports (animation-timeline: view()) {
  .home-scroll-reveal {
    opacity: 0;
    transform: translateY(48px) scale(0.98);
    filter: blur(8px);
    animation: homeScrollReveal 1s var(--ease-out-quart) both;
    animation-timeline: view();
    animation-range: entry 8% cover 36%;
  }

  .home-login-section__pass.home-scroll-reveal {
    animation-range: entry 12% cover 42%;
  }
}

@media (prefers-reduced-motion: reduce) {
  .home-cover__shape,
  .home-cover__copy-reveal {
    opacity: 1 !important;
    transform: none !important;
    animation: none !important;
    will-change: auto;
  }

  .home-cover__ghost {
    transform: translate(-50%, -50%) !important;
  }

  .home-scroll-reveal {
    opacity: 1 !important;
    transform: none !important;
    filter: none !important;
    animation: none !important;
  }
}

@media (max-width: 820px) {
  .home-cover {
    min-height: 92svh;
    padding: calc(var(--nav-height) + var(--spacing-xl)) 0 var(--spacing-section);
  }

  .home-cover__copy {
    text-align: left;
  }

  .home-cover__title {
    font-size: clamp(46px, 15vw, 68px);
  }

  .home-cover__subtitle {
    margin-left: 0;
    margin-right: 0;
  }

  .home-cover__ghost {
    font-size: 72px;
    white-space: normal;
    text-align: center;
  }

  .home-cover__paper--one {
    left: -120px;
  }

  .home-cover__paper--two {
    right: -96px;
  }

  .home-login-cta {
    min-height: 30vh;
    padding: var(--spacing-xxl) var(--spacing-lg);
  }

  .home-login-cta__button {
    width: min(100%, 320px);
    padding: 0 var(--spacing-lg);
  }

  .home-login-section {
    align-items: start;
    min-height: auto;
    padding: calc(var(--nav-height) + var(--spacing-lg)) 0 var(--spacing-xxl);
  }

  .home-login-section__inner {
    grid-template-columns: 1fr;
    gap: var(--spacing-lg);
  }
}
</style>

<script>
  function initHomeLoginScroll() {
    const target = document.querySelector('#login')
    const triggers = document.querySelectorAll('[data-home-login-scroll]')
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (!target || !triggers.length) return

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault()
        target.scrollIntoView({
          behavior: prefersReducedMotion ? 'auto' : 'smooth',
          block: 'start',
        })
        history.replaceState(null, '', '#login')
      })
    })
  }

  initHomeLoginScroll()
  document.addEventListener('astro:page-load', initHomeLoginScroll)
</script>
