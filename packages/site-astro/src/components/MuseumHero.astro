---
import VisitorPass from './VisitorPass.vue'
interface Props {
  apiBase: string
  heroEyebrow: string
  heroTitle: string
  heroSubtitle: string
}

const { apiBase, heroEyebrow, heroTitle, heroSubtitle } = Astro.props
---

<section class="home-cover" aria-labelledby="museum-hero-title">
  <!-- 噪点纹理覆盖层 -->
  <div class="home-cover__noise" aria-hidden="true" />

  <!-- 径向渐变暗角 -->
  <div class="home-cover__vignette" aria-hidden="true" />

  <!-- 环境装饰 -->
  <div class="home-cover__ambient" aria-hidden="true">
    <span class="home-cover__shape home-cover__paper home-cover__paper--one" data-parallax='{"speed": 0.15}'></span>
    <span class="home-cover__shape home-cover__paper home-cover__paper--two" data-parallax='{"speed": 0.25}'></span>
    <span class="home-cover__shape home-cover__paper home-cover__paper--three" data-parallax='{"speed": 0.35}'></span>
    <span class="home-cover__shape home-cover__film" data-parallax='{"speed": 0.4}'></span>
    <!-- 替换 CLASS MEMORY 为更克制的装饰 -->
    <div class="home-cover__deco-line" aria-hidden="true" data-parallax='{"speed": 0.1}'></div>
  </div>

  <div class="home-cover__copy container" data-parallax='{"speed": -0.2}'>
    <p class="home-cover__kicker home-cover__copy-reveal" style="--reveal-delay: 0.28s">{heroEyebrow}</p>
    <h1 id="museum-hero-title" class="home-cover__title">
      <span class="home-cover__copy-reveal" style="--reveal-delay: 0.46s">{heroTitle}</span>
      <span class="home-cover__copy-reveal" style="--reveal-delay: 0.62s">翻开青春</span>
    </h1>
    <p class="home-cover__subtitle home-cover__copy-reveal" style="--reveal-delay: 0.84s">{heroSubtitle}</p>
  </div>

  <div class="home-cover__scroll-slot">
    <div class="home-cover__scroll-reveal home-cover__copy-reveal" style="--reveal-delay: 1.08s">
      <a href="#login" class="home-cover__scroll" data-home-login-scroll aria-label="向下滑动到登录入口">
        <span>向下滑动</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>

<section class="home-login-cta" aria-label="进入登录">
  <a href="#login" class="home-login-cta__button home-scroll-reveal" data-testid="home-login-cta" data-home-login-scroll>
    翻开同学录，进入登录
  </a>
</section>

<section id="login" class="home-login-section" aria-labelledby="home-login-title">
  <div class="home-login-section__inner container">
    <div class="home-login-section__copy home-scroll-reveal">
      <p class="home-cover__kicker">CLASSMATE PASS</p>
      <h2 id="home-login-title" class="display-sm">身份验证</h2>
      <p>输入自己的同学账号与密码。首次登录后，系统会引导你把初始密码换成专属密码。</p>
    </div>
    <div class="home-login-section__pass home-scroll-reveal">
      <VisitorPass client:visible apiBase={apiBase} />
    </div>
  </div>
</section>

<style>
.home-cover {
  position: relative;
  min-height: 100svh;
  display: grid;
  place-items: center;
  overflow: hidden;
  padding: calc(var(--nav-height) + var(--space-6)) 0 var(--space-7);
  background:
    linear-gradient(180deg, rgba(15, 13, 11, 0.08), rgba(15, 13, 11, 0.88)),
    radial-gradient(circle at 18% 28%, rgba(200, 169, 106, 0.18), transparent 32%),
    radial-gradient(circle at 78% 72%, rgba(188, 79, 60, 0.16), transparent 34%),
    #11100e;
  color: var(--text-inverse);
}

/* 噪点纹理 */
.home-cover__noise {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 256px 256px;
  z-index: 1;
}

/* 径向渐变暗角 */
.home-cover__vignette {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(ellipse at center, transparent 0%, transparent 50%, rgba(0, 0, 0, 0.4) 100%);
  z-index: 2;
}

.home-cover__ambient {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.home-cover__shape {
  --shape-x: 0px;
  --shape-y: 0px;
  --shape-rotate: 0deg;
  --shape-enter-delay: 0s;
  --parallax-y: 0px;
  opacity: 0;
  transform: translate3d(var(--shape-x), calc(var(--shape-y) - 150px + var(--parallax-y)), 0) rotate(calc(var(--shape-rotate) - 15deg));
  animation: homeShapeEnter 2.2s cubic-bezier(0.23, 0.86, 0.39, 0.96) var(--shape-enter-delay) forwards;
  will-change: transform, opacity;
}

.home-cover__paper {
  position: absolute;
  height: 54px;
  width: 260px;
  border-radius: var(--radius-pill);
  border: 1px solid rgba(251, 246, 236, 0.12);
  background: rgba(251, 246, 236, 0.04);
  box-shadow: var(--shadow-skeuo-md, 0 8px 32px rgba(0, 0, 0, 0.12));
  backdrop-filter: blur(4px);
}

.home-cover__paper--one {
  left: -42px;
  top: 20%;
  width: 360px;
  --shape-rotate: -13deg;
  --shape-enter-delay: 0.18s;
  box-shadow: var(--shadow-skeuo-lg, 0 16px 48px rgba(0, 0, 0, 0.16));
}

.home-cover__paper--two {
  right: 12%;
  top: 16%;
  --shape-rotate: 19deg;
  --shape-enter-delay: 0.34s;
  background: rgba(200, 169, 106, 0.07);
  box-shadow: var(--shadow-skeuo-sm, 0 4px 16px rgba(0, 0, 0, 0.08));
}

.home-cover__paper--three {
  right: -58px;
  bottom: 18%;
  width: 320px;
  --shape-rotate: -16deg;
  --shape-enter-delay: 0.46s;
  background: rgba(188, 79, 60, 0.06);
  box-shadow: var(--shadow-skeuo-md, 0 12px 36px rgba(0, 0, 0, 0.14));
}

.home-cover__film {
  position: absolute;
  left: 7%;
  bottom: 12%;
  width: 190px;
  height: 44px;
  border-radius: var(--radius-md);
  border: 1px solid rgba(251, 246, 236, 0.11);
  background:
    repeating-linear-gradient(90deg, rgba(251, 246, 236, 0.08) 0 10px, transparent 10px 20px),
    rgba(251, 246, 236, 0.025);
  --shape-rotate: -8deg;
  --shape-enter-delay: 0.58s;
  box-shadow: var(--shadow-skeuo-md, 0 10px 30px rgba(0, 0, 0, 0.2));
}

/* 装饰线 - 替代原来的 CLASS MEMORY */
.home-cover__deco-line {
  position: absolute;
  left: 50%;
  top: 55%;
  --parallax-y: 0px;
  transform: translateX(-50%) translateY(var(--parallax-y));
  width: 120px;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(200, 169, 106, 0.3), transparent);
  --shape-rotate: 0deg;
  --shape-enter-delay: 0.72s;
  will-change: transform;
}

.home-cover__copy {
  position: relative;
  z-index: 3;
  max-width: 920px;
  text-align: center;
  --parallax-y: 0px;
  transform: translateY(var(--parallax-y));
  will-change: transform;
}

.home-cover__kicker {
  margin-bottom: var(--space-5);
  color: var(--gold);
  font-size: var(--type-caption-uppercase);
  font-weight: var(--weight-medium);
  letter-spacing: var(--tracking-widest);
  text-transform: uppercase;
}

.home-cover__title {
  display: grid;
  gap: var(--space-2);
  margin: 0;
  color: #fffaf2;
  font-family: var(--font-display);
  font-size: clamp(56px, 10vw, 120px);
  font-weight: var(--weight-semibold);
  line-height: 0.92;
  letter-spacing: var(--tracking-tight);
  text-shadow: 0 16px 48px rgba(0, 0, 0, 0.35);
}

.home-cover__copy-reveal {
  --reveal-delay: 0s;
  opacity: 0;
  transform: translateY(30px);
  animation: homeCopyReveal 1s cubic-bezier(0.25, 0.4, 0.25, 1) forwards;
  animation-delay: var(--reveal-delay);
}

.home-cover__subtitle {
  max-width: 680px;
  margin: var(--space-6) auto 0;
  color: rgba(255, 250, 242, 0.78);
  font-size: clamp(16px, 1.6vw, 20px);
  line-height: 1.85;
}

.home-cover__scroll-slot {
  position: absolute;
  left: 50%;
  bottom: var(--space-6);
  z-index: 4;
  transform: translateX(-50%);
}

.home-cover__scroll-reveal { display: inline-block; }

.home-cover__scroll {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  min-height: 38px;
  padding: 0 var(--space-5);
  border: 1px solid rgba(255, 250, 242, 0.22);
  border-radius: var(--radius-pill);
  color: rgba(255, 250, 242, 0.76);
  font-size: var(--type-body-sm);
  text-decoration: none;
  transition:
    border-color var(--duration-fast) var(--ease-out-expo),
    color var(--duration-fast) var(--ease-out-expo),
    transform var(--duration-fast) var(--ease-out-expo);
}

.home-cover__scroll:hover {
  color: #fffaf2;
  border-color: rgba(255, 250, 242, 0.46);
  transform: translateY(-2px);
}

.home-login-cta {
  position: relative;
  display: grid;
  place-items: center;
  min-height: 36vh;
  padding: var(--space-9) var(--space-5);
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 250, 242, 0.28), transparent 34%),
    linear-gradient(180deg, #11100e 0%, #211d17 24%, var(--bg) 78%);
}

.home-login-cta__button {
  display: inline-flex;
  min-height: 52px;
  align-items: center;
  justify-content: center;
  padding: 0 var(--space-6);
  border: 1px solid rgba(255, 250, 242, 0.22);
  border-radius: var(--radius-pill);
  background: var(--bg-surface);
  color: var(--text-primary);
  box-shadow: var(--shadow-lg);
  font-weight: var(--weight-semibold);
  text-decoration: none;
  transition:
    background-color var(--duration-fast) var(--ease-out-expo),
    box-shadow var(--duration-fast) var(--ease-out-expo),
    transform var(--duration-fast) var(--ease-out-expo);
}

.home-login-cta__button:hover {
  background: var(--bg-soft);
  box-shadow: 0 16px 40px rgba(76, 59, 38, 0.14);
  transform: translateY(-2px);
}

.home-login-section {
  min-height: 100svh;
  display: grid;
  align-items: center;
  padding: calc(var(--nav-height) + var(--space-6)) 0 var(--space-9);
  background:
    var(--texture-paper-fiber),
    var(--bg);
  background-size: 100% 100%, 100% 26px;
  scroll-margin-top: var(--nav-height);
}

.home-login-section__inner {
  display: grid;
  grid-template-columns: minmax(0, 0.86fr) minmax(320px, 460px);
  gap: var(--space-7);
  align-items: center;
}

.home-login-section__copy {
  max-width: 520px;
  color: var(--text-primary);
}

.home-login-section__copy h2 {
  margin: var(--space-3) 0 var(--space-4);
  color: var(--text-primary);
}

.home-login-section__copy p:not(.home-cover__kicker) {
  color: var(--text-muted);
  line-height: 1.9;
}

.home-login-section__pass {
  transition:
    transform var(--duration-slow) var(--ease-out-expo),
    box-shadow var(--duration-slow) var(--ease-out-expo);
}

.home-login-section__pass:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-card-hover);
}

.home-scroll-reveal {
  opacity: 1;
  transform: translateY(0) scale(1);
}

@keyframes homeScrollReveal {
  from {
    opacity: 0;
    transform: translateY(48px) scale(0.98);
    filter: blur(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes homeShapeEnter {
  0% {
    opacity: 0;
    transform: translate3d(var(--shape-x), calc(var(--shape-y) - 150px + var(--parallax-y, 0px)), 0) rotate(calc(var(--shape-rotate) - 15deg));
  }
  54% {
    opacity: 1;
  }
  100% {
    opacity: 1;
    transform: translate3d(var(--shape-x), calc(var(--shape-y) + var(--parallax-y, 0px)), 0) rotate(var(--shape-rotate));
  }
}

@keyframes homeCopyReveal {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@supports (animation-timeline: view()) {
  .home-scroll-reveal {
    opacity: 0;
    transform: translateY(48px) scale(0.98);
    filter: blur(8px);
    animation: homeScrollReveal 1s var(--ease-out-expo) both;
    animation-timeline: view();
    animation-range: entry 8% cover 36%;
  }

  .home-login-section__pass.home-scroll-reveal {
    animation-range: entry 12% cover 42%;
  }
}

@media (prefers-reduced-motion: reduce) {
  .home-cover__shape,
  .home-cover__deco-line,
  .home-cover__copy-reveal {
    opacity: 1 !important;
    transform: none !important;
    animation: none !important;
    will-change: auto;
  }

  .home-scroll-reveal {
    opacity: 1 !important;
    transform: none !important;
    filter: none !important;
    animation: none !important;
  }
}

@media (max-width: 820px) {
  .home-cover {
    min-height: 92svh;
    padding: calc(var(--nav-height) + var(--space-6)) 0 var(--space-9);
  }

  .home-cover__copy {
    text-align: left;
  }

  .home-cover__title {
    font-size: clamp(46px, 15vw, 68px);
  }

  .home-cover__subtitle {
    margin-left: 0;
    margin-right: 0;
  }

  .home-cover__paper--one {
    left: -120px;
  }

  .home-cover__paper--two {
    right: -96px;
  }

  .home-login-cta {
    min-height: 30vh;
    padding: var(--space-7) var(--space-5);
  }

  .home-login-cta__button {
    width: min(100%, 320px);
    padding: 0 var(--space-5);
  }

  .home-login-section {
    align-items: start;
    min-height: auto;
    padding: calc(var(--nav-height) + var(--space-5)) 0 var(--space-7);
  }

  .home-login-section__inner {
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
}
</style>

<script>
  let cleanupParallax = () => {}
  let cleanupLoginScroll = () => {}

  function initParallax() {
    cleanupParallax()
    const elements = document.querySelectorAll<HTMLElement>('[data-parallax]')
    if (!elements.length || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    let rafId: number | null = null
    let ticking = false
    const updateParallax = () => {
      const scrollY = window.scrollY
      if (scrollY > window.innerHeight * 1.5) {
        ticking = false
        rafId = null
        return
      }
      elements.forEach((element) => {
        try {
          const speed = JSON.parse(element.getAttribute('data-parallax') || '{}').speed || 0
          element.style.setProperty('--parallax-y', `${scrollY * speed}px`)
        } catch {}
      })
      ticking = false
      rafId = null
    }
    const onScroll = () => {
      if (!ticking) {
        rafId = requestAnimationFrame(updateParallax)
        ticking = true
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true })
    cleanupParallax = () => {
      window.removeEventListener('scroll', onScroll)
      if (rafId !== null) cancelAnimationFrame(rafId)
      rafId = null
      ticking = false
    }
  }

  function initHomeLoginScroll() {
    cleanupLoginScroll()
    const target = document.querySelector<HTMLElement>('#login')
    const triggers = Array.from(document.querySelectorAll<HTMLElement>('[data-home-login-scroll]'))
    if (!target || !triggers.length) return
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const onClick = (event: Event) => {
      event.preventDefault()
      target.scrollIntoView({ behavior: prefersReducedMotion ? 'auto' : 'smooth', block: 'start' })
      history.replaceState(null, '', '#login')
    }
    triggers.forEach((trigger) => trigger.addEventListener('click', onClick))
    cleanupLoginScroll = () => triggers.forEach((trigger) => trigger.removeEventListener('click', onClick))
  }

  function initMuseumHeroRuntime() {
    initHomeLoginScroll()
    initParallax()
  }

  window.addEventListener('pageshow', initMuseumHeroRuntime)
  window.addEventListener('pagehide', (event) => {
    if (!(event as PageTransitionEvent).persisted) {
      cleanupLoginScroll()
      cleanupParallax()
    }
  })
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initMuseumHeroRuntime, { once: true })
  else initMuseumHeroRuntime()
</script>
