---
import IconBrand from './icons/IconBrand.astro'
const currentPath = Astro.url.pathname
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const href = (path: string) => `${base}${path.replace(/^\/+/, '')}`
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)
---
<nav class="top-nav">
  <div class="nav-inner container">
    <a href={href('/')} class="nav-brand">
      <span class="brand-mark"><IconBrand size={20} /></span>
      <span class="brand-text">同学录</span>
    </a>
    <input type="checkbox" id="menu-toggle" class="menu-toggle-input" />
    <label for="menu-toggle" class="mobile-toggle" aria-label="菜单">
      <span class="toggle-bar"></span>
    </label>
    <div class="nav-links">
      <a href={href('/preface')} class={`nav-link ${currentPath.startsWith(href('/preface')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/preface')) ? 'page' : undefined}>
        <span class="link-text">前言</span>
        <span class="lamp-glow"></span>
      </a>
      <a href={href('/roster')} class={`nav-link ${currentPath.startsWith(href('/roster')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/roster')) ? 'page' : undefined}>
        <span class="link-text">同学录</span>
        <span class="lamp-glow"></span>
      </a>
      <a href={href('/album')} class={`nav-link ${currentPath.startsWith(href('/album')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/album')) ? 'page' : undefined}>
        <span class="link-text">相册</span>
        <span class="lamp-glow"></span>
      </a>
      <a href={href('/timeline')} class={`nav-link ${currentPath.startsWith(href('/timeline')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/timeline')) ? 'page' : undefined}>
        <span class="link-text">时光轴</span>
        <span class="lamp-glow"></span>
      </a>
      <a href={href('/yearbook')} class={`nav-link ${currentPath.startsWith(href('/yearbook')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/yearbook')) ? 'page' : undefined}>
        <span class="link-text">年度册 (PDF)</span>
        <span class="lamp-glow"></span>
      </a>
      
      <!-- 静态与客户端完全一致的已登录身份栏：0 水合开销，0 nextTick 黑洞，彻底消灭消失又出现的闪烁 -->
      <div id="classmate-nav-session" class="nav-session" style="display: none;">
        <span id="classmate-nav-name" class="session-name">同学</span>
        <button id="classmate-nav-logout" class="btn-logout">退出</button>
      </div>

      <!-- 同步点亮及绑定退出登录的原生极速 inline 脚本 -->
      <script is:inline define:vars={{ CLIENT_API_BASE }}>
        (function() {
          try {
            const studentStr = sessionStorage.getItem('classmate_student');
            const token = sessionStorage.getItem('classmate_account_token');
            if (studentStr && token) {
              const student = JSON.parse(studentStr);
              if (student && student.name) {
                const el = document.getElementById('classmate-nav-session');
                const nameEl = document.getElementById('classmate-nav-name');
                const logoutBtn = document.getElementById('classmate-nav-logout');
                
                if (el && nameEl && logoutBtn) {
                  nameEl.textContent = student.name + '同学';
                  el.style.display = 'flex';
                  
                  // 绑定退出登录点击行为
                  logoutBtn.addEventListener('click', async function() {
                    if (confirm('确认关闭并退出你的纪念册？')) {
                      try {
                        // 在后台静默发送登出请求
                        await fetch(CLIENT_API_BASE + '/api/classmate-auth/logout', {
                          method: 'POST',
                          headers: { 'X-Classmate-Token': token }
                        });
                      } catch (e) {}
                      sessionStorage.clear();
                      window.location.href = '/';
                    }
                  });
                }
              }
            }
          } catch (e) {}
        })();
      </script>
    </div>
  </div>
</nav>

<style>
  /* 悬浮胶囊毛玻璃顶栏 */
  .top-nav {
    position: fixed;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: 820px; /* 固定宽度，彻底消除不同页面间因滚动条产生的抖动与长度忽大忽小 */
    max-width: calc(100% - 2.5rem);
    height: 54px;
    background-color: rgba(250, 249, 245, 0.85); /* 复古胶皮纸暖白 */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-hairline);
    border-radius: 9999px;
    box-shadow: 0 8px 30px rgba(62, 50, 35, 0.05);
    transition: all var(--duration-normal) var(--ease-out-quart);
  }
  
  /* 滚动时紧贴和加深 */
  .top-nav.scrolled {
    top: 0.75rem;
    background-color: rgba(250, 249, 245, 0.93);
    box-shadow: 0 10px 35px rgba(62, 50, 35, 0.08),
                0 1px 3px rgba(62, 50, 35, 0.02);
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: 0 1.5rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    text-decoration: none;
    color: var(--color-ink);
  }

  .brand-mark { 
    font-size: 18px; 
    color: var(--color-primary); 
    display: flex;
    align-items: center;
  }

  .brand-text { 
    font-family: var(--font-display); 
    font-size: 19px; 
    font-weight: 600; 
    letter-spacing: 0.05em; 
  }

  .nav-links { 
    display: flex; 
    align-items: center; 
    gap: var(--spacing-xs); 
    margin-left: auto; 
  }

  /* 导航项 */
  .nav-link {
    position: relative;
    padding: 6px 14px;
    font-size: var(--type-nav-link-size);
    font-weight: var(--type-nav-link-weight);
    color: var(--color-muted);
    border-radius: var(--rounded-md);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quart),
              background-color var(--duration-fast) var(--ease-out-quart);
  }

  .nav-link:hover { 
    color: var(--color-ink); 
    background-color: rgba(62, 50, 35, 0.03); 
  }

  /* Active 状态 */
  .nav-link.active {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* 复古床头灯泡渐变光晕 (Tubelight / Lamp Effect) */
  .nav-link.active .lamp-glow {
    position: absolute;
    top: -4px; /* 贴近胶囊上边缘 */
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 2px;
    background-color: var(--color-primary);
    border-radius: 9999px;
    box-shadow: 
      0 0 10px rgba(204, 120, 92, 0.95),
      0 0 20px rgba(204, 120, 92, 0.5),
      0 0 35px rgba(204, 120, 92, 0.25);
  }

  /* 静态与客户端完全一致的已登录排版样式 */
  .nav-session {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-left: var(--spacing-xs);
    padding-left: var(--spacing-sm);
    border-left: 1px solid var(--color-hairline);
    font-size: var(--type-nav-link-size);
    height: 20px;
  }

  .session-name {
    color: var(--color-muted);
    font-weight: 500;
    white-space: nowrap;
  }

  .btn-logout {
    background: none;
    border: none;
    color: #cc785c;
    cursor: pointer;
    padding: 0;
    font-weight: 500;
    transition: color var(--duration-fast);
    white-space: nowrap;
  }

  .btn-logout:hover {
    color: #b36349;
  }

  .menu-toggle-input { display: none; }
  .mobile-toggle { display: none; width: 36px; height: 36px; align-items: center; justify-content: center; margin-left: auto; cursor: pointer; }
  .toggle-bar, .toggle-bar::before, .toggle-bar::after {
    display: block; width: 20px; height: 2px;
    background-color: var(--color-ink); border-radius: 1px;
    transition: transform var(--duration-normal) var(--ease-out-quart),
              background-color var(--duration-normal) var(--ease-out-quart);
  }
  .toggle-bar { position: relative; }
  .toggle-bar::before, .toggle-bar::after { content: ''; position: absolute; left: 0; }
  .toggle-bar::before { top: -6px; }
  .toggle-bar::after { top: 6px; }

  /* 响应式断点 */
  @media (max-width: 768px) {
    .top-nav {
      top: 1rem;
      width: calc(100% - 1.5rem);
    }
    .mobile-toggle { display: flex; }
    .nav-links {
      position: fixed;
      top: 64px;
      left: 0; right: 0;
      flex-direction: column;
      background-color: rgba(250, 249, 245, 0.96);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--color-hairline);
      border-radius: 20px;
      padding: var(--spacing-lg);
      gap: var(--spacing-xs);
      box-shadow: 0 15px 35px rgba(62, 50, 35, 0.1);
      opacity: 0; visibility: hidden;
      pointer-events: none;
      transform: translateY(-10px);
      transition: all 0.25s var(--ease-out-quart);
    }
    .menu-toggle-input:checked ~ .nav-links {
      opacity: 1; visibility: visible; pointer-events: auto;
      transform: translateY(0);
    }
    .nav-link { 
      font-size: 16px; 
      padding: 10px 16px; 
      width: 100%;
      text-align: center;
    }
    .nav-link.active .lamp-glow {
      top: auto;
      bottom: 2px;
      width: 24px;
    }
    .nav-session {
      border-left: none;
      border-top: 1px solid var(--color-hairline);
      margin-left: 0;
      padding-left: 0;
      padding-top: var(--spacing-sm);
      width: 100%;
      height: auto;
      justify-content: center;
    }
  }

  .menu-toggle-input:checked ~ .mobile-toggle .toggle-bar {
    background-color: transparent;
  }
  .menu-toggle-input:checked ~ .mobile-toggle .toggle-bar::before {
    top: 0;
    transform: rotate(45deg);
  }
  .menu-toggle-input:checked ~ .mobile-toggle .toggle-bar::after {
    top: 0;
    transform: rotate(-45deg);
  }
</style>

<script>
  const nav = document.querySelector('.top-nav')
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('scrolled', window.scrollY > 10)
    }
    window.addEventListener('scroll', onScroll, { passive: true })
    onScroll()

    // --- 极速阻尼物理滑移灯管算法 (Spring Beziers Sliding Lamp) ---
    const links = Array.from(nav.querySelectorAll('.nav-link')) as HTMLElement[]
    const activeLink = nav.querySelector('.nav-link.active') as HTMLElement
    
    if (activeLink) {
      const activeIndex = links.indexOf(activeLink)
      const prevIndexStr = localStorage.getItem('prev_nav_index')
      
      if (prevIndexStr !== null) {
        const prevIndex = parseInt(prevIndexStr, 10)
        if (prevIndex !== activeIndex && prevIndex >= 0 && prevIndex < links.length) {
          const prevLink = links[prevIndex]
          
          // 计算上一个活动 Tab 与当前活动 Tab 中心在水平上的偏差像素
          const dx = prevLink.offsetLeft + (prevLink.offsetWidth / 2) - (activeLink.offsetLeft + (activeLink.offsetWidth / 2))
          
          const glow = activeLink.querySelector('.lamp-glow') as HTMLElement
          if (glow) {
            // 1. 瞬间定位灯光（无过渡动画）
            glow.style.transition = 'none'
            glow.style.transform = `translateX(calc(-50% + ${dx}px))`
            
            // 2. 强制 Reflow
            glow.offsetHeight
            
            // 3. 采用高度拟合 spring(300, 30) 的高回弹阻尼贝塞尔曲线进行滑移动效
            glow.style.transition = 'transform 0.48s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.48s cubic-bezier(0.34, 1.56, 0.64, 1)'
            glow.style.transform = 'translateX(-50%)'
            glow.style.boxShadow = `
              0 0 10px rgba(204, 120, 92, 0.95),
              0 0 20px rgba(204, 120, 92, 0.5),
              0 0 35px rgba(204, 120, 92, 0.25)
            `
          }
        }
      }
      
      localStorage.setItem('prev_nav_index', activeIndex.toString())
    }

    links.forEach((link, idx) => {
      link.addEventListener('click', () => {
        localStorage.setItem('prev_nav_index', idx.toString())
      })
    })
  }
</script>
