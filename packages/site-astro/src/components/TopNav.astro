---
import IconBrand from './icons/IconBrand.astro'
const currentPath = Astro.url.pathname
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const href = (path: string) => `${base}${path.replace(/^\/+/, '')}`
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)
const isHome = currentPath === base || currentPath === href('/')
---
<nav class={`top-nav paper-bookmark-nav ${isHome ? 'top-nav--home' : ''}`}>
  <div class="nav-inner container">
    <a href={href('/')} class="nav-brand">
      <span class="brand-mark"><IconBrand size={20} /></span>
      <span class="brand-text">同学录</span>
    </a>
    <input type="checkbox" id="menu-toggle" class="menu-toggle-input" />
    <label for="menu-toggle" class="mobile-toggle" aria-label="菜单">
      <span class="toggle-bar"></span>
    </label>
    <div class="nav-links">
      <a href={href('/preface')} class={`nav-link ${currentPath.startsWith(href('/preface')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/preface')) ? 'page' : undefined}>
        <span class="link-text">前言</span>
        {currentPath.startsWith(href('/preface')) && <span class="ink-line" transition:name="active-ink-line"></span>}
      </a>
      <a href={href('/roster')} class={`nav-link ${currentPath.startsWith(href('/roster')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/roster')) ? 'page' : undefined}>
        <span class="link-text">同学录</span>
        {currentPath.startsWith(href('/roster')) && <span class="ink-line" transition:name="active-ink-line"></span>}
      </a>
      <a href={href('/messages')} class={`nav-link nav-link--community ${currentPath.startsWith(href('/messages')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/messages')) ? 'page' : undefined}>
        <span class="link-text">公共留言</span>
        {currentPath.startsWith(href('/messages')) && <span class="ink-line" transition:name="active-ink-line"></span>}
      </a>
      <a href={href('/mailbox')} class={`nav-link nav-link--mail ${currentPath.startsWith(href('/mailbox')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/mailbox')) ? 'page' : undefined}>
        <span class="link-text">班级邮局</span>
        <span id="mail-unread-stamp" class="mail-unread-stamp" hidden></span>
        {currentPath.startsWith(href('/mailbox')) && <span class="ink-line" transition:name="active-ink-line"></span>}
      </a>
      <a href={href('/album')} class={`nav-link ${currentPath.startsWith(href('/album')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/album')) ? 'page' : undefined}>
        <span class="link-text">相册</span>
        {currentPath.startsWith(href('/album')) && <span class="ink-line" transition:name="active-ink-line"></span>}
      </a>
      <a href={href('/timeline')} class={`nav-link ${currentPath.startsWith(href('/timeline')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/timeline')) ? 'page' : undefined}>
        <span class="link-text">时光轴</span>
        {currentPath.startsWith(href('/timeline')) && <span class="ink-line" transition:name="active-ink-line"></span>}
      </a>
      <a href={href('/yearbook')} class={`nav-link ${currentPath.startsWith(href('/yearbook')) ? 'active' : ''}`} aria-current={currentPath.startsWith(href('/yearbook')) ? 'page' : undefined}>
        <span class="link-text">年度册 (PDF)</span>
        {currentPath.startsWith(href('/yearbook')) && <span class="ink-line" transition:name="active-ink-line"></span>}
      </a>
      
      <!-- 静态与客户端完全一致的已登录身份栏：0 水合开销，0 nextTick 黑洞，彻底消灭消失又出现的闪烁 -->
      <div id="classmate-nav-session" class="nav-session" style="display: none;">
        <span id="classmate-nav-name" class="session-name">同学</span>
        <button id="classmate-nav-logout" class="btn-logout">退出</button>
      </div>

      <!-- 同步点亮静态登录态的原生极速 inline 脚本 -->
      <script is:inline define:vars={{ CLIENT_API_BASE }}>
        function syncNavSession() {
          try {
            const studentStr = sessionStorage.getItem('classmate_account_student');
            const token = sessionStorage.getItem('classmate_account_token');
            const el = document.getElementById('classmate-nav-session');
            const nameEl = document.getElementById('classmate-nav-name');
            const logoutBtn = document.getElementById('classmate-nav-logout');
            const nav = document.querySelector('.top-nav');
            
            if (studentStr && token) {
              if (nav) nav.classList.add('has-session');
              const student = JSON.parse(studentStr);
              if (student && student.name && el && nameEl && logoutBtn) {
                nameEl.textContent = student.name + '同学';
                el.style.display = 'flex';
                
                // 重新绑定退出登录点击行为，防止 DOM 替换后事件丢失
                logoutBtn.onclick = async function() {
                  if (confirm('确认关闭并退出你的纪念册？')) {
                    try {
                      await fetch(CLIENT_API_BASE + '/api/classmate-auth/logout', {
                        method: 'POST',
                        headers: { 'X-Classmate-Token': token }
                      });
                    } catch (e) {}
                    sessionStorage.clear();
                    window.location.href = '/';
                  }
                };
              }
            } else {
              if (nav) nav.classList.remove('has-session');
              if (el) el.style.display = 'none';
            }
          } catch (e) {}
        }
        
        async function syncMailUnread() {
          try {
            const token = sessionStorage.getItem('classmate_account_token');
            const stamp = document.getElementById('mail-unread-stamp');
            if (!stamp || !token) {
              if (stamp) stamp.hidden = true;
              return;
            }
            const res = await fetch(CLIENT_API_BASE + '/api/notifications/summary', {
              headers: { 'X-Classmate-Token': token }
            });
            if (!res.ok) return;
            const data = await res.json();
            const count = data && data.data ? Number(data.data.unreadCount || 0) : 0;
            stamp.hidden = count <= 0;
            stamp.textContent = count > 99 ? '99+' : String(count);
          } catch (e) {}
        }
        
        // 1. 首帧同步执行（First Paint 之前同步点亮）
        syncNavSession();
        syncMailUnread();
        
        // 2. 视图过渡跳转后重新校验并绑定事件
        document.addEventListener('astro:page-load', syncNavSession);
        document.addEventListener('astro:page-load', syncMailUnread);
      </script>
    </div>
  </div>
</nav>

<style>
  .top-nav--home:not(.has-session) {
    width: 220px;
  }

  .top-nav--home:not(.has-session) .nav-links {
    display: none;
  }

  .top-nav--home:not(.has-session) .nav-inner {
    justify-content: center;
  }

  .top-nav--home:not(.has-session) .nav-brand {
    margin-inline: auto;
  }

  /* 悬浮胶囊毛玻璃顶栏 */
  .top-nav {
    position: fixed;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: 820px; /* 固定宽度，彻底消除不同页面间因滚动条产生的抖动与长度忽大忽小 */
    max-width: calc(100% - 2.5rem);
    height: 54px;
    background-color: color-mix(in srgb, var(--color-paper-card) 86%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-paper-border);
    border-radius: 9999px;
    box-shadow: var(--shadow-paper-card);
    transition: all var(--duration-normal) var(--ease-out-quart);
  }
  
  /* 滚动时紧贴和加深 */
  .top-nav.scrolled {
    top: 0.75rem;
    background-color: color-mix(in srgb, var(--color-paper-card) 94%, transparent);
    box-shadow: var(--shadow-paper-panel);
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: 0 1.5rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    text-decoration: none;
    color: var(--color-paper-ink);
  }

  .brand-mark { 
    font-size: 18px; 
    color: var(--color-paper-brown); 
    display: flex;
    align-items: center;
  }

  .brand-text { 
    font-family: var(--font-display); 
    font-size: 19px; 
    font-weight: 600; 
    letter-spacing: 0.05em; 
  }

  .nav-links { 
    display: flex; 
    align-items: center; 
    gap: var(--spacing-xs); 
    margin-left: auto; 
  }

  /* 导航项 */
  .nav-link {
    position: relative;
    padding: 6px 14px;
    font-size: var(--type-nav-link-size);
    font-weight: var(--type-nav-link-weight);
    color: var(--color-paper-muted);
    border-radius: var(--rounded-md);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-quart),
              background-color var(--duration-fast) var(--ease-out-quart);
  }

  .nav-link:hover { 
    color: var(--color-paper-ink); 
    background-color: color-mix(in srgb, var(--color-paper-brown) 10%, transparent); 
  }

  /* Active 状态 */
  .nav-link.active {
    color: var(--color-paper-brown);
    font-weight: 600;
  }

  .paper-bookmark-nav {
    border-radius: 18px 18px 16px 16px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-paper-card) 92%, transparent), color-mix(in srgb, var(--color-paper-card) 82%, transparent)),
      repeating-linear-gradient(90deg, rgba(112, 86, 55, 0.05) 0 1px, transparent 1px 8px);
    border-color: color-mix(in srgb, var(--color-paper-border) 82%, var(--color-paper-brown));
    box-shadow: 0 14px 34px rgba(74, 50, 29, 0.12), inset 0 1px 0 rgba(255,255,255,0.55);
  }

  .paper-bookmark-nav::before {
    content: '';
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: -1px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(117, 77, 40, 0.28), transparent);
    pointer-events: none;
  }

  .ink-line {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 4px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, var(--color-paper-brown), var(--color-paper-stamp-red), transparent);
    transform-origin: center;
    animation: inkLineFlow 2.8s ease-in-out infinite;
  }

  .mail-unread-stamp {
    position: absolute;
    top: -8px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    line-height: 1;
    color: #fffaf2;
    background: var(--color-paper-stamp-red);
    box-shadow: 0 2px 8px rgba(130, 42, 33, 0.24);
  }

  .mail-unread-stamp[hidden] {
    display: none;
  }

  @keyframes inkLineFlow {
    0%, 100% { opacity: 0.72; transform: scaleX(0.88); }
    50% { opacity: 1; transform: scaleX(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ink-line {
      animation: none;
    }
  }

  /* 静态与客户端完全一致的已登录排版样式 */
  .nav-session {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-left: var(--spacing-xs);
    padding-left: var(--spacing-sm);
    border-left: 1px solid var(--color-paper-border);
    font-size: var(--type-nav-link-size);
    height: 20px;
  }

  .session-name {
    color: var(--color-paper-muted);
    font-weight: 500;
    white-space: nowrap;
  }

  .btn-logout {
    background: none;
    border: none;
    color: var(--color-paper-stamp-red);
    cursor: pointer;
    padding: 0;
    font-weight: 500;
    transition: color var(--duration-fast);
    white-space: nowrap;
  }

  .btn-logout:hover {
    color: var(--color-paper-brown-active);
  }

  .menu-toggle-input { display: none; }
  .mobile-toggle { display: none; width: 36px; height: 36px; align-items: center; justify-content: center; margin-left: auto; cursor: pointer; }
  .toggle-bar, .toggle-bar::before, .toggle-bar::after {
    display: block; width: 20px; height: 2px;
    background-color: var(--color-paper-ink); border-radius: 1px;
    transition: transform var(--duration-normal) var(--ease-out-quart),
              background-color var(--duration-normal) var(--ease-out-quart);
  }
  .toggle-bar { position: relative; }
  .toggle-bar::before, .toggle-bar::after { content: ''; position: absolute; left: 0; }
  .toggle-bar::before { top: -6px; }
  .toggle-bar::after { top: 6px; }

  /* 响应式断点 */
  @media (max-width: 768px) {
    .top-nav {
      top: 1rem;
      width: calc(100% - 1.5rem);
    }
    .mobile-toggle { display: flex; }
    .nav-links {
      position: fixed;
      top: 64px;
      left: 0; right: 0;
      flex-direction: column;
      background-color: color-mix(in srgb, var(--color-paper-card) 96%, transparent);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--color-paper-border);
      border-radius: 20px;
      padding: var(--spacing-lg);
      gap: var(--spacing-xs);
      box-shadow: var(--shadow-paper-panel);
      opacity: 0; visibility: hidden;
      pointer-events: none;
      transform: translateY(-10px);
      transition: all 0.25s var(--ease-out-quart);
      max-height: calc(100vh - 80px);
      overflow-y: auto;
    }
    .menu-toggle-input:checked ~ .nav-links {
      opacity: 1; visibility: visible; pointer-events: auto;
      transform: translateY(0);
    }
    .nav-link { 
      font-size: 16px; 
      padding: 10px 16px; 
      width: 100%;
      text-align: center;
    }
    .nav-link.active .ink-line {
      top: auto;
      bottom: 2px;
      width: 24px;
      left: calc(50% - 12px); /* 50% 居中减去自身宽度的一半 */
      right: auto;            /* 覆盖可能继承 of right 定位 */
    }
    .nav-session {
      border-left: none;
      border-top: 1px solid var(--color-paper-border);
      margin-left: 0;
      padding-left: 0;
      padding-top: var(--spacing-sm);
      width: 100%;
      height: auto;
      justify-content: center;
    }

    .top-nav--home:not(.has-session) {
      width: min(220px, calc(100% - 1.5rem));
    }

    .top-nav--home:not(.has-session) .mobile-toggle {
      display: none;
    }

    .nav-link--mail {
      display: flex !important;
      justify-content: center;
      align-items: center;
      gap: 6px;
    }
    .nav-link--mail .mail-unread-stamp {
      position: static !important;
    }
  }

  .menu-toggle-input:checked ~ .mobile-toggle .toggle-bar {
    background-color: transparent;
  }
  .menu-toggle-input:checked ~ .mobile-toggle .toggle-bar::before {
    top: 0;
    transform: rotate(45deg);
  }
  .menu-toggle-input:checked ~ .mobile-toggle .toggle-bar::after {
    top: 0;
    transform: rotate(-45deg);
  }
</style>

<script>
  let topNavScrollCleanup

  function initScroll() {
    if (topNavScrollCleanup) topNavScrollCleanup()
    const nav = document.querySelector('.top-nav')
    if (nav) {
      const onScroll = () => {
        nav.classList.toggle('scrolled', window.scrollY > 10)
      }
      window.addEventListener('scroll', onScroll, { passive: true })
      topNavScrollCleanup = () => {
        window.removeEventListener('scroll', onScroll)
      }
      onScroll()
    }
  }

  // 1. 首屏加载时初始化滚动检测
  initScroll();

  // 2. 每次视图过渡跳转完毕后，重新绑定滚动检测
  document.addEventListener('astro:page-load', initScroll);
</script>
