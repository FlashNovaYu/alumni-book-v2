---
import IconBrand from './icons/IconBrand.astro'

const currentPath = Astro.url.pathname
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const href = (path: string) => {
  const match = path.match(/^([^?#]*)(.*)$/)
  const pathname = (match?.[1] || '').replace(/^\/+/, '')
  const suffix = match?.[2] || ''
  const normalizedPath = pathname && !pathname.endsWith('/') ? `${pathname}/` : pathname
  return `${base}${normalizedPath}${suffix}`
}
const adminHref = href('/admin/#/classmate')
const isHome = currentPath === base || currentPath === href('/')
const navItems = [
  { href: '/preface', label: '前言' },
  { href: '/roster', label: '同学档案' },
  { href: '/class-space', label: '班级空间' },
  { href: '/yearbook', label: '年度册' },
  { href: '/more', label: '更多' },
]
const isActive = (path: string) => currentPath === href(path) || currentPath.startsWith(href(path))
const pageTitle = navItems.find((item) => isActive(item.href))?.label || '同学录'
---

<nav class={`top-nav paper-bookmark-nav ${isHome ? 'top-nav--home' : ''}`} aria-label="主导航">
  <div class="nav-inner ticket-container">
    <!-- 左侧：票根存根 (Logo区) -->
    <div class="ticket-stub-left">
      <div class="ticket-punch-top"></div>
      <div class="ticket-punch-bottom"></div>
      <a href={href('/')} class="nav-brand nav-brand--stub" data-nav-home aria-label="同学录首页">
        <span class="brand-mark"><IconBrand size={22} /></span>
        <span class="brand-text">同学录</span>
      </a>
      <button class="mobile-nav-button" type="button" data-nav-open data-audio-hover aria-label="打开目录">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>

    <!-- 中部：主票面 (导航区) -->
    <div class="ticket-main">
      <a href={href('/')} class="nav-brand nav-brand--center" data-nav-home aria-label="同学录首页">
        <span class="brand-mark"><IconBrand size={22} /></span>
        <span class="brand-text">同学录</span>
      </a>
      <p class="mobile-page-title" aria-live="polite">{pageTitle}</p>
      <div class="nav-directory" data-nav-directory data-nav-ready="true">
        <span class="nav-active-paper" aria-hidden="true"></span>
        <span class="nav-active-ink ink-line" aria-hidden="true"><span class="nav-active-ink-fill"></span></span>
        {navItems.map((item) => (
          <a
            href={href(item.href)}
            class={`nav-link ${isActive(item.href) ? 'is-active' : ''}`}
            data-nav-item
            data-audio-hover
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <!-- 右侧：副券 (工具栏区) -->
    <div class="ticket-stub-right">
      <div class="ticket-punch-top"></div>
      <div class="ticket-punch-bottom"></div>
      <div class="nav-utilities">
        <button class="nav-theme-button nav-theme-button--desktop" type="button" data-theme-toggle aria-label="切换为夜读模式" aria-pressed="false" title="切换夜读模式">
          <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v2.5M12 18.5V21M3 12h2.5M18.5 12H21M5.64 5.64l1.77 1.77M16.59 16.59l1.77 1.77M18.36 5.64l-1.77 1.77M7.41 16.59l-1.77 1.77" /><circle cx="12" cy="12" r="3.5" /></svg>
        </button>
        <button class="nav-volume-button" type="button" data-volume-toggle data-audio-hover aria-label="关闭页面音效" aria-pressed="false" title="关闭页面音效">
          <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 10v4h4l5 4V6l-5 4H4Z" /><path d="M17 9.5a4 4 0 0 1 0 5M19.5 7a7 7 0 0 1 0 10" /></svg>
        </button>
        <a href={adminHref} class="nav-admin-button" data-nav-admin-entry>管理</a>
        <a
          href={href('/account')}
          class="nav-account-button"
          data-nav-session-only
          hidden
          aria-label="账号中心"
          title="账号中心"
        >
          <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="3.25" /><path d="M5.5 20c.7-3.4 3-5.1 6.5-5.1s5.8 1.7 6.5 5.1" /></svg>
        </a>
        <a
          href={href('/mailbox')}
          class={`nav-mailbox-button ${isActive('/mailbox') ? 'is-active' : ''}`}
          data-nav-session-only
          hidden
          aria-label="班级信箱"
          title="班级信箱"
        >
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="1.5" /><path d="m4 7 8 5 8-5" /></svg>
          <span class="mail-unread-stamp" data-nav-unread hidden></span>
        </a>
        <button class="nav-theme-button nav-theme-button--mobile" type="button" data-theme-toggle aria-label="切换为夜读模式" aria-pressed="false" title="切换夜读模式">
          <svg viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v2.5M12 18.5V21M3 12h2.5M18.5 12H21M5.64 5.64l1.77 1.77M16.59 16.59l1.77 1.77M18.36 5.64l-1.77 1.77M7.41 16.59l-1.77 1.77" /><circle cx="12" cy="12" r="3.5" /></svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<div class="mobile-drawer-overlay" data-nav-overlay></div>
<aside class="mobile-drawer" data-nav-drawer role="dialog" aria-modal="true" aria-labelledby="mobile-drawer-title" aria-hidden="true" inert>
  <header class="drawer-header">
    <div>
      <p class="drawer-kicker">CLASS ARCHIVE</p>
      <strong id="mobile-drawer-title">目录</strong>
    </div>
    <button class="drawer-icon-button" type="button" data-nav-close aria-label="关闭目录">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18" /></svg>
    </button>
  </header>

  <div class="drawer-account" data-nav-session-only hidden>
    <span>当前登录</span>
    <strong data-nav-student-name>同学</strong>
    <a href={href('/account')}>进入账号中心</a>
  </div>

  <div class="drawer-links">
    {navItems.map((item) => (
      <a href={href(item.href)} data-audio-hover class={`drawer-link ${isActive(item.href) ? 'is-active' : ''}`}>
        <span>{item.label}</span>
        {isActive(item.href) && <span class="drawer-active-mark" aria-hidden="true"></span>}
      </a>
    ))}
  </div>

  <footer class="drawer-footer" data-nav-session-only hidden>
    <a href={adminHref} class="drawer-mail-link" data-nav-admin-entry>管理后台</a>
    <a href={href('/mailbox')} class="drawer-mail-link">
      <span>班级信箱</span>
      <span class="mail-unread-stamp" data-nav-unread hidden></span>
    </a>
    <button type="button" class="drawer-logout-button" data-nav-logout>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 6V4h9v16h-9v-2" /><path d="m13 12-4 0m2-3-3 3 3 3" /></svg>
      退出登录
    </button>
  </footer>
</aside>

<style>
  :global([data-theme="dark"]) {
    --color-body-bg: var(--bg-surface, #1e1b18);
  }

  .top-nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    min-height: calc(var(--nav-height) + 16px);
    background-color: transparent;
  }

  .top-nav.is-scrolled .ticket-container {
    filter: drop-shadow(0 8px 24px rgba(74, 50, 29, 0.12));
  }

  .nav-inner {
    min-height: var(--nav-height);
    display: flex;
    align-items: stretch;
    gap: var(--spacing-md);
  }

  /* Ticket styles */
  .ticket-container {
    position: relative;
    display: flex;
    align-items: stretch;
    background: var(--color-paper-card);
    border-bottom: 1px solid color-mix(in srgb, var(--color-paper-brown) 32%, var(--color-paper-border));
    filter: drop-shadow(0 4px 15px rgba(96, 65, 35, 0.08));
    margin: 0;
    padding: 0;
    transition: filter var(--duration-normal) ease;
  }

  .ticket-stub-left, .ticket-stub-right {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0 var(--spacing-lg);
  }

  .ticket-stub-left {
    border-right: 2px dashed color-mix(in srgb, var(--color-paper-brown) 30%, var(--color-paper-border));
    background: var(--color-paper-bg-soft);
    border-radius: 6px 0 0 6px;
  }

  .ticket-stub-right {
    border-left: 2px dashed color-mix(in srgb, var(--color-paper-brown) 30%, var(--color-paper-border));
  }

  .ticket-main {
    flex: 1;
    display: flex;
    align-items: stretch;
    justify-content: center;
  }

  .ticket-punch-top, .ticket-punch-bottom {
    position: absolute;
    width: 12px;
    height: 12px;
    background: var(--color-body-bg, #fdfbf7); /* Match body background */
    border-radius: 50%;
    z-index: 2;
  }

  .ticket-stub-left .ticket-punch-top { right: -7px; top: -7px; border-bottom: 1px solid var(--color-paper-border); }
  .ticket-stub-left .ticket-punch-bottom { right: -7px; bottom: -7px; border-top: 1px solid var(--color-paper-border); }
  
  .ticket-stub-right .ticket-punch-top { left: -7px; top: -7px; border-bottom: 1px solid var(--color-paper-border); }
  .ticket-stub-right .ticket-punch-bottom { left: -7px; bottom: -7px; border-top: 1px solid var(--color-paper-border); }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    align-self: center;
    color: var(--color-paper-ink);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-brand--center {
    display: none;
  }

  .brand-mark {
    display: inline-flex;
    width: auto;
    height: auto;
    align-items: center;
    justify-content: center;
    color: var(--color-paper-stamp-red);
    border: 0;
    background: transparent;
  }

  .brand-text {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0;
  }

  .nav-directory {
    position: relative;
    display: flex;
    align-items: stretch;
    justify-content: center;
    min-width: 0;
  }

  .nav-link {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 76px;
    padding: 0 12px;
    color: var(--color-paper-muted);
    font-family: var(--font-serif, serif); /* Enforce serif for archival feel */
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 1px;
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .nav-link:hover,
  .nav-link.is-active { color: var(--color-paper-ink); }

  .nav-link.is-active::before,
  .nav-link.is-active::after {
    position: absolute;
    right: 0;
    left: 0;
    pointer-events: none;
    content: '';
  }

  .nav-link.is-active::before {
    top: 9px;
    bottom: 8px;
    z-index: -1;
    border: 1px solid color-mix(in srgb, var(--color-paper-brown) 32%, var(--color-paper-border));
    background: var(--color-paper-bg-soft);
    box-shadow: inset 0 1px 0 var(--glass-panel);
  }

  .nav-link.is-active::after {
    bottom: 6px;
    z-index: 2;
    height: 3px;
    background: var(--color-paper-stamp-red);
    transform-origin: left center;
  }

  .nav-directory[data-nav-direction='backward'] .nav-link.is-active::after {
    transform-origin: right center;
  }

  .nav-active-paper,
  .nav-active-ink {
    position: absolute;
    left: 0;
    pointer-events: none;
    opacity: 0;
  }

  .nav-active-paper {
    top: 9px;
    bottom: 8px;
    z-index: 0;
    border: 1px solid color-mix(in srgb, var(--color-paper-brown) 32%, var(--color-paper-border));
    background: var(--color-paper-bg-soft);
    box-shadow: inset 0 1px 0 var(--glass-panel);
    transition: transform var(--duration-normal) var(--ease-out-quart), width var(--duration-normal) var(--ease-out-quart), opacity var(--duration-fast) ease;
  }

  .nav-active-ink {
    bottom: 6px;
    z-index: 2;
    height: 3px;
    overflow: hidden;
    transition: transform var(--duration-normal) var(--ease-out-quart), width var(--duration-normal) var(--ease-out-quart), opacity var(--duration-fast) ease;
  }

  .nav-active-ink-fill {
    position: absolute;
    inset: 0;
    display: block;
    background: var(--color-paper-stamp-red);
    height: 3px; /* Slightly thicker */
    transform: scaleX(1);
    transform-origin: left center;
    transition: transform var(--duration-normal) var(--ease-out-quart);
  }

  .nav-directory[data-nav-direction='backward'] .nav-active-ink-fill { transform-origin: right center; }
  .nav-directory[data-nav-revealing='true'] .nav-active-ink-fill { transform: scaleX(0); }
  .nav-directory[data-nav-ready='false'] .nav-active-paper,
  .nav-directory[data-nav-ready='false'] .nav-active-ink,
  .nav-directory[data-nav-ready='false'] .nav-active-ink-fill { transition: none; }

  .nav-utilities {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .nav-account-button,
  .nav-mailbox-button,
  .nav-theme-button,
  .nav-volume-button,
  .mobile-nav-button,
  .drawer-icon-button {
    display: inline-grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 0;
    color: var(--color-paper-muted);
    background: transparent;
    text-decoration: none;
    cursor: pointer;
    transition: color var(--duration-fast) ease, background-color var(--duration-fast) ease;
  }

  .nav-account-button:hover,
  .nav-mailbox-button:hover,
  .nav-mailbox-button.is-active,
  .nav-theme-button:hover,
  .nav-volume-button:hover,
  .mobile-nav-button:hover,
  .drawer-icon-button:hover {
    color: var(--color-paper-ink);
    background: color-mix(in srgb, var(--color-paper-brown) 10%, transparent);
  }

  .nav-mailbox-button { position: relative; }
  .nav-theme-button { border: 0; font: inherit; }
  .nav-theme-button--mobile { display: none; }
  .nav-admin-button {
    display: none;
    align-self: center;
    padding: 5px 8px;
    color: var(--color-paper-brown);
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid var(--color-paper-border);
  }

  :global(html.has-admin-entry) .nav-admin-button { display: inline-flex; }
  .drawer-footer [data-nav-admin-entry] { display: none; }
  :global(html.has-admin-entry) .drawer-footer [data-nav-admin-entry] { display: flex; }

  .mail-unread-stamp {
    position: absolute;
    top: 1px;
    right: 1px;
    min-width: 17px;
    height: 17px;
    padding: 0 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-inverse);
    background: var(--color-paper-stamp-red);
    border-radius: 9px;
    font-size: 10px;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .mail-unread-stamp[hidden] { display: none; }

  .mobile-nav-button,
  .mobile-page-title { display: none; }

  .mobile-drawer-overlay {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-nav) + 1);
    visibility: hidden;
    background: rgba(46, 34, 22, 0.28);
    opacity: 0;
    transition: opacity var(--duration-normal) ease, visibility var(--duration-normal) ease;
  }

  .mobile-drawer {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: calc(var(--z-nav) + 2);
    display: flex;
    width: min(320px, calc(100vw - 40px));
    flex-direction: column;
    color: var(--color-paper-ink);
    background: var(--color-paper-card);
    border-right: 1px solid var(--color-paper-border);
    box-shadow: 10px 0 26px rgba(74, 50, 29, 0.14);
    transform: translateX(-102%);
    transition: transform var(--duration-normal) var(--ease-out-quart);
  }

  :global(html.nav-open) { overflow: hidden; }
  :global(html.nav-open) .mobile-drawer-overlay { visibility: visible; opacity: 1; }
  :global(html.nav-open) .mobile-drawer { transform: translateX(0); }

  .drawer-header {
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--spacing-lg);
    border-bottom: 1px solid var(--color-paper-border);
  }

  .drawer-header p,
  .drawer-header strong { display: block; margin: 0; }
  .drawer-header strong { font-family: var(--font-display); font-size: 22px; }
  .drawer-kicker { color: var(--color-paper-muted); font-size: 10px; letter-spacing: 0.12em; }

  .drawer-account {
    display: grid;
    gap: 4px;
    margin: var(--spacing-md) var(--spacing-lg) 0;
    padding: var(--spacing-md);
    background: var(--color-paper-bg-soft);
    border: 1px solid var(--color-paper-border);
  }

  .drawer-account span { color: var(--color-paper-muted); font-size: 12px; }
  .drawer-account strong { font-size: 16px; }
  .drawer-account a { color: var(--color-paper-brown); font-size: 13px; text-decoration: none; }

  .drawer-links {
    display: grid;
    gap: 2px;
    padding: var(--spacing-lg);
  }

  .drawer-link,
  .drawer-mail-link {
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--spacing-sm);
    color: var(--color-paper-muted);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-paper-border) 70%, transparent);
  }

  .drawer-link.is-active { color: var(--color-paper-ink); font-weight: 700; }
  .drawer-active-mark { width: 20px; height: 2px; background: var(--color-paper-stamp-red); }

  .drawer-footer {
    display: grid;
    gap: var(--spacing-xs);
    margin-top: auto;
    padding: var(--spacing-md) var(--spacing-lg) var(--spacing-lg);
    border-top: 1px solid var(--color-paper-border);
  }

  .drawer-mail-link { position: relative; padding-right: 28px; }
  .drawer-mail-link .mail-unread-stamp { top: 13px; right: 7px; }

  .drawer-logout-button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: var(--color-paper-stamp-red);
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--color-paper-stamp-red) 28%, var(--color-paper-border));
    font: inherit;
    cursor: pointer;
  }

  .top-nav--home:not(.has-session) .nav-directory,
  .top-nav--home:not(.has-session) .mobile-nav-button,
  .top-nav--home:not(.has-session) .mobile-page-title { display: none; }
  .top-nav--home:not(.has-session) .nav-brand--stub { display: none; }
  .top-nav--home:not(.has-session) .nav-brand--center {
    display: inline-flex;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  @media (max-width: 980px) {
    .nav-link { min-width: 0; padding: 0 9px; font-size: 13px; }
    .nav-inner { gap: var(--spacing-xs); }
  }

  @media (max-width: 768px) {
    .top-nav { min-height: 52px; }
    .ticket-container { margin: 0; border: none; border-bottom: 1px solid color-mix(in srgb, var(--color-paper-brown) 15%, var(--color-paper-border)); filter: none; }
    .ticket-stub-left, .ticket-stub-right { border: none; background: transparent; padding: 0 12px; }
    .ticket-punch-top, .ticket-punch-bottom { display: none; }
    .nav-inner {
      min-height: 52px;
      padding: 0;
    }
    .nav-brand,
    .nav-directory,
    .nav-account-button,
    .nav-theme-button--desktop { display: none; }
    .nav-theme-button--mobile { display: inline-grid; }
    .mobile-nav-button { display: inline-grid; }
    .mobile-page-title {
      position: absolute;
      left: 50%;
      top: 50%;
      max-width: calc(100% - 132px);
      pointer-events: none;
      transform: translate(-50%, -50%);
      display: block;
      overflow: hidden;
      margin: 0;
      color: var(--color-paper-ink);
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 600;
      line-height: 52px;
      text-align: center;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .nav-utilities { justify-content: flex-end; }
    .nav-mailbox-button { width: 44px; height: 44px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-active-paper,
    .nav-active-ink,
    .mobile-drawer,
    .mobile-drawer-overlay { transition: none; }
  }
</style>
