---
import MainLayout from '../../layouts/MainLayout.astro'
import StudentProfile from '../../components/StudentProfile.vue'

export async function getStaticPaths() {
  async function fetchWithRetry(url: string, retries = 4, delay = 1000): Promise<any> {
    for (let attempt = 0; attempt <= retries; attempt++) {
      try {
        const res = await fetch(url)
        if (!res.ok) {
          throw new Error(`HTTP ${res.status}`)
        }
        return await res.json()
      } catch (e: any) {
        if (attempt === retries) {
          throw e
        }
        console.warn(`[slug].astro getStaticPaths fetch failed (attempt ${attempt + 1}/${retries + 1}) for ${url}: ${e.message}. Retrying in ${delay}ms...`)
        await new Promise(r => setTimeout(r, delay))
        delay *= 2
      }
    }
  }

  const API_BASE = import.meta.env.VITE_WORKER_URL || 'https://alumni-book.pages.dev'
  let classmates: any[] = []
  try {
    const data = await fetchWithRetry(`${API_BASE}/api/classmates`)
    classmates = data.data || []
  } catch (e: any) {
    console.error(`❌ [slug].astro getStaticPaths failed to fetch classmates: ${e.message}. Aborting build.`)
    throw e
  }
  return classmates.map(c => ({ params: { slug: c.slug } }))
}

const { slug } = Astro.params

const API_BASE = import.meta.env.VITE_WORKER_URL || 'https://alumni-book.pages.dev'
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const href = (path: string) => `${base}${path.replace(/^\/+/, '')}`
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)

async function fetchWithRetry(url: string, retries = 4, delay = 1000): Promise<any> {
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const res = await fetch(url)
      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }
      return await res.json()
    } catch (e: any) {
      if (attempt === retries) {
        throw e
      }
      console.warn(`[slug].astro fetch failed (attempt ${attempt + 1}/${retries + 1}) for ${url}: ${e.message}. Retrying in ${delay}ms...`)
      await new Promise(r => setTimeout(r, delay))
      delay *= 2
    }
  }
}

let student: any = null
try {
  const data = await fetchWithRetry(`${API_BASE}/api/students/${slug}?audience=public`)
  if (data.success && data.data) student = data.data
} catch (e: any) {
  console.error(`❌ [slug].astro failed to fetch student detail for ${slug}: ${e.message}. Aborting build.`)
  throw e
}

if (!student) {
  return Astro.redirect(href('/roster'))
}

let museum = {
  enabled: true,
  enableClassGraph: false,
  enableSeatMap: false,
}

try {
  const configRes = await fetch(`${API_BASE}/api/config`)
  const configJson = await configRes.json()
  museum = { ...museum, ...(configJson.data?.museum || {}) }
} catch {}

// 测试或本地开发构建时，默认开启亮点卡片以保证 Playwright E2E 网络测试覆盖
if (!process.env.VITE_WORKER_URL || process.env.NODE_ENV === 'test') {
  museum.enableClassGraph = true
  museum.enableSeatMap = true
}
---

<MainLayout>
  <StudentProfile client:load initialStudent={student} studentSlug={slug} apiBase={CLIENT_API_BASE} museum={museum} />
</MainLayout>

