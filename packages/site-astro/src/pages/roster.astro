---
import MainLayout from '../layouts/MainLayout.astro'
import RosterWall from '../components/RosterWall.vue'
import RankingsPanel from '../components/RankingsPanel.vue'
import ClassGraphPreview from '../components/ClassGraphPreview.vue'
import SeatMapPreview from '../components/SeatMapPreview.vue'

interface Classmate {
  name: string; slug: string; hasPage: boolean
  avatarUrl: string | null; motto: string
}

const API_BASE = import.meta.env.VITE_WORKER_URL || 'https://alumni-book-api.chenyuhao2263.workers.dev'
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const href = (path: string) => `${base}${path.replace(/^\/+/, '')}`
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)

async function fetchWithRetry(url: string, retries = 4, delay = 1000): Promise<any> {
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const res = await fetch(url)
      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }
      return await res.json()
    } catch (e: any) {
      if (attempt === retries) {
        throw e
      }
      console.warn(`roster.astro fetch failed (attempt ${attempt + 1}/${retries + 1}) for ${url}: ${e.message}. Retrying in ${delay}ms...`)
      await new Promise(r => setTimeout(r, delay))
      delay *= 2
    }
  }
}

let classmates: Classmate[] = []
try {
  const data = await fetchWithRetry(`${API_BASE}/api/classmates`)
  classmates = data.data || []
} catch (e: any) {
  console.error(`❌ roster.astro failed to fetch classmates: ${e.message}. Aborting build.`)
  throw e
}

let museum = {
  enabled: true,
  enableClassGraph: false,
  enableSeatMap: false,
}

try {
  const configJson = await fetchWithRetry(`${API_BASE}/api/config`)
  museum = { ...museum, ...(configJson.data?.museum || {}) }
} catch (e: any) {
  console.error(`❌ roster.astro failed to fetch config: ${e.message}. Aborting build.`)
  throw e
}

// 测试或本地开发构建时，默认开启亮点卡片以保证 Playwright E2E 网络测试覆盖
if (!process.env.VITE_WORKER_URL || process.env.NODE_ENV === 'test') {
  museum.enableClassGraph = true
  museum.enableSeatMap = true
}
---

<MainLayout>
  <div class="roster-page page-shell">
    <div class="container">
      <header class="page-header fade-in">
        <p class="page-header__label">ARCHIVE CORRIDOR</p>
        <h1 class="display-lg">人物长廊</h1>
        <p class="page-header__subtitle">用档案检索重新遇见每一位同学</p>
      </header>

      <RankingsPanel client:visible apiBase={CLIENT_API_BASE} />

      <RosterWall client:load initialClassmates={classmates} apiBase={CLIENT_API_BASE} siteBase={base} />

      {museum.enabled && (museum.enableClassGraph || museum.enableSeatMap) && (
        <div class="lazy-highlights paper-highlight-grid">
          {museum.enableClassGraph && <ClassGraphPreview client:visible apiBase={CLIENT_API_BASE} sampleNames={classmates.slice(0, 5).map((c) => c.name)} />}
          {museum.enableSeatMap && <SeatMapPreview client:visible apiBase={CLIENT_API_BASE} seats={classmates.map((c: any) => c.seatNo).filter(Boolean).slice(0, 8)} />}
        </div>
      )}
    </div>
  </div>
</MainLayout>

<style>
  .lazy-highlights {
    margin-top: var(--spacing-xl);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }
  @media (max-width: 768px) {
    .lazy-highlights {
      grid-template-columns: 1fr;
    }
  }
  .avatar-char { font-family: var(--font-display); font-size: 28px; font-weight: 500; color: var(--color-muted); }
  @media (max-width: 768px) {
    .card-avatar { width: 58px; height: 58px; }
  }
</style>

