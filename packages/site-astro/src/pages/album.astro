---
import MainLayout from '../layouts/MainLayout.astro'
import IconCamera from '../components/icons/IconCamera.astro'
import AlbumGrid from '../components/AlbumGrid.vue'

interface Album {
  id: string; title: string; description: string; frameStyle: string
  sortOrder: number; photos: Photo[]; createdAt: string
}
interface Photo {
  id: string; albumId: string; filename: string; caption: string
  r2Key: string; sortOrder: number; createdAt: string
}

const API_BASE = import.meta.env.VITE_WORKER_URL || 'https://alumni-book-api.chenyuhao2263.workers.dev'
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)

async function fetchWithRetry(url: string, retries = 4, delay = 1000): Promise<any> {
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const res = await fetch(url)
      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }
      return await res.json()
    } catch (e: any) {
      if (attempt === retries) {
        throw e
      }
      console.warn(`album.astro fetch failed (attempt ${attempt + 1}/${retries + 1}) for ${url}: ${e.message}. Retrying in ${delay}ms...`)
      await new Promise(r => setTimeout(r, delay))
      delay *= 2
    }
  }
}

let albums: Album[] = []
try {
  const data = await fetchWithRetry(`${API_BASE}/api/albums`)
  albums = data.data || []
} catch (e: any) {
  console.error(`❌ album.astro failed to fetch albums: ${e.message}. Aborting build.`)
  throw e
}
---

<MainLayout>
  <div class="album-page section">
    <div class="container">
      <div class="album-header fade-in">
        <p class="museum-kicker">IMAGE GALLERY</p>
        <h1 class="album-title display-lg">影像馆</h1>
        <p class="album-subtitle">每一幅影像，都是一段珍贵的回忆</p>
      </div>

      {albums.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon"><IconCamera size={48} /></div>
          <p>暂无影像</p>
          <p>请前往管理后台上传</p>
        </div>
      ) : (
        <AlbumGrid client:load albums={albums} apiBase={CLIENT_API_BASE} />
      )}
    </div>
  </div>
</MainLayout>

<style>
  .album-page { padding-top: calc(var(--nav-height) + var(--spacing-section)); }
  .album-header { text-align: center; margin-bottom: var(--spacing-xl); }
  .museum-kicker {
    font-size: var(--type-caption-uppercase-size);
    font-weight: var(--type-caption-uppercase-weight);
    letter-spacing: var(--type-caption-uppercase-letter-spacing);
    color: var(--color-muted);
    margin-bottom: var(--spacing-md);
  }
  .album-subtitle { font-size: var(--type-body-sm-size); color: var(--color-muted); margin-top: var(--spacing-sm); }
  .empty-state { text-align: center; padding: 80px 20px; color: var(--color-muted); }
  .empty-icon { font-size: 48px; margin-bottom: var(--spacing-md); opacity: 0.3; }
</style>
