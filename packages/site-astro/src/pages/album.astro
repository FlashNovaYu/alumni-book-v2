---
import MainLayout from '../layouts/MainLayout.astro'
import AlbumGrid from '../components/AlbumGrid.vue'
import PageHeader from '../components/PageHeader.astro'
import { normalizeLegacyFileUrls } from '../../../../workers/api/src/lib/fileUrl'

interface Album {
  id: string; title: string; description: string; frameStyle: string
  sortOrder: number; photos: Photo[]; createdAt: string
}
interface Photo {
  id: string; albumId: string; filename: string; caption: string
  r2Key: string; sortOrder: number; createdAt: string
}

const API_BASE = import.meta.env.VITE_WORKER_URL || 'https://alumni-book.pages.dev'
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)

async function fetchWithRetry(url: string, retries = 4, delay = 1000): Promise<any> {
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const res = await fetch(url)
      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }
      return normalizeLegacyFileUrls(await res.json())
    } catch (e: any) {
      if (attempt === retries) {
        throw e
      }
      console.warn(`album.astro fetch failed (attempt ${attempt + 1}/${retries + 1}) for ${url}: ${e.message}. Retrying in ${delay}ms...`)
      await new Promise(r => setTimeout(r, delay))
      delay *= 2
    }
  }
}

let albums: Album[] = []
try {
  const data = await fetchWithRetry(`${API_BASE}/api/albums`)
  albums = data.data || []
} catch (e: any) {
  console.error(`❌ album.astro failed to fetch albums: ${e.message}. Aborting build.`)
  throw e
}
---

<MainLayout>
  <div class="album-page page-shell">
    <div class="container">
      <PageHeader label="IMAGE GALLERY" title="影像馆" subtitle="每一幅影像，都是一段珍贵的回忆" />
      <AlbumGrid client:load albums={albums} apiBase={CLIENT_API_BASE} />
    </div>
  </div>
</MainLayout>
