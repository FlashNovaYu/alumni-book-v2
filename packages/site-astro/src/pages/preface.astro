---
import MainLayout from '../layouts/MainLayout.astro'
import PrefaceWall from '../components/PrefaceWall.vue'

const API_BASE = import.meta.env.VITE_WORKER_URL || 'https://alumni-book.pages.dev'
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const href = (path: string) => `${base}${path.replace(/^\/+/, '')}`
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)

let config: any = {
  preface: { title: '致青春岁月', subtitle: '写在翻开同学录之前', content: '' },
  acknowledgments: [],
}

async function fetchWithRetry(url: string, retries = 4, delay = 1000): Promise<any> {
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const res = await fetch(url)
      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }
      return await res.json()
    } catch (e: any) {
      if (attempt === retries) {
        throw e
      }
      console.warn(`preface.astro fetch failed (attempt ${attempt + 1}/${retries + 1}) for ${url}: ${e.message}. Retrying in ${delay}ms...`)
      await new Promise(r => setTimeout(r, delay))
      delay *= 2
    }
  }
}

try {
  const data = await fetchWithRetry(`${API_BASE}/api/config`)
  if (data.success && data.data) config = data.data
} catch (e: any) {
  console.error(`❌ preface.astro failed to fetch config: ${e.message}. Aborting build.`)
  throw e
}
---

<MainLayout>
  <div class="preface-page page-shell">
    <div class="container">
      <header class="page-header fade-in">
        <p class="page-header__label">PREFACE LETTER</p>
        <h1 class="display-lg">{config.preface?.title || '致青春岁月'}</h1>
        <p class="page-header__subtitle">{config.preface?.subtitle || '写在翻开同学录之前'}</p>
      </header>

      <PrefaceWall client:load initialConfig={config} apiBase={CLIENT_API_BASE} />

      <div class="bottom-actions fade-in">
        <a href={href('/roster')} class="btn-primary">翻阅同学档案</a>
        <a href={href('/class-space')} class="btn-secondary">前往班级空间</a>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .bottom-actions {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
    margin-top: var(--spacing-xxl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--color-paper-border);
  }

  @media (max-width: 768px) {
    .bottom-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
