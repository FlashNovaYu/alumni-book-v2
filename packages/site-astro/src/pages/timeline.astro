---
import MainLayout from '../layouts/MainLayout.astro'
import { normalizeLegacyFileUrls } from '../../../../workers/api/src/lib/fileUrl'

const API_BASE = import.meta.env.VITE_WORKER_URL || 'https://alumni-book.pages.dev'
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const href = (path: string) => `${base}${path.replace(/^\/+/, '')}`
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)

let items: any[] = []
async function fetchWithRetry(url: string, retries = 4, delay = 1000): Promise<any> {
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const res = await fetch(url)
      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }
      return normalizeLegacyFileUrls(await res.json())
    } catch (e: any) {
      if (attempt === retries) {
        throw e
      }
      console.warn(`timeline.astro fetch failed (attempt ${attempt + 1}/${retries + 1}) for ${url}: ${e.message}. Retrying in ${delay}ms...`)
      await new Promise(r => setTimeout(r, delay))
      delay *= 2
    }
  }
}

try {
  const data = await fetchWithRetry(`${API_BASE}/api/timeline`)
  items = data.data || []
} catch (e: any) {
  console.error(`❌ timeline.astro failed to fetch timeline: ${e.message}. Aborting build.`)
  throw e
}
---

<MainLayout>
  <div class="timeline-page page-shell" data-base-url={base} data-api-base={CLIENT_API_BASE}>
    <div class="container">
      <header class="page-header fade-in">
        <p class="page-header__label">CLASS TIMELINE</p>
        <h1 class="display-lg">时光轴</h1>
        <p class="page-header__subtitle">把重要瞬间按时间慢慢装订成册</p>
      </header>

      <!-- Tab 筛选栏 -->
      <div class="timeline-tabs fade-in">
        <button class="tab-btn active" data-type="all">全部</button>
        <button class="tab-btn" data-type="event">班级大事</button>
        <button class="tab-btn" data-type="message">新留言</button>
        <button class="tab-btn" data-type="photo">新照片</button>
        <button class="tab-btn" data-type="join">新同学页</button>
      </div>

      <div class="timeline-line">
        {items.map((item, i) => (
          <div class={`timeline-node anim-enter ${item.isMilestone ? 'milestone' : ''} type-${item.type}`} style={`animation-delay: ${Math.min(i * 0.05, 0.4)}s`}>
            <div class="tl-dot"></div>
            <div class="tl-card">
              <div class="tl-date">{new Date(item.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
              <h3 class="tl-title">{item.title}</h3>
              {item.description && <p class="tl-desc">{item.description}</p>}
              {item.photoUrl && (
                <img src={item.photoUrl.startsWith('http') ? item.photoUrl : `${API_BASE}${item.photoUrl}`} alt="" loading="lazy" decoding="async" style="aspect-ratio: 4/3" class="tl-photo" />
              )}
              {item.type === 'join' && item.slug && (
                <a href={href(`/student/${item.slug}`)} class="tl-link">查看 TA 的主页 →</a>
              )}
            </div>
          </div>
        ))}
      </div>

      {items.length === 0 && (
        <div class="empty-state">
          <p>校史走廊尚未写入内容</p>
        </div>
      )}
    </div>
  </div>
  <script id="timeline-data" type="application/json" set:html={JSON.stringify(items)}></script>
</MainLayout>

<script>
  const dataEl = document.getElementById('timeline-data')
  let allItems = JSON.parse(dataEl?.textContent || '[]')
  const pageEl = document.querySelector('.timeline-page')
  const base = pageEl?.getAttribute('data-base-url') || '/'
  const API_BASE = pageEl?.getAttribute('data-api-base') || ''
  const href = (path: string) => `${base}${path.replace(/^\/+/, '')}`

  // SWR: 抓取最新时光轴数据并更新渲染
  fetch(`${API_BASE}/api/timeline`)
    .then(r => r.json())
    .then(data => {
      if (data.success && data.data) {
        if (JSON.stringify(data.data) === JSON.stringify(allItems)) return
        allItems = data.data
        const activeTab = document.querySelector('.timeline-tabs .tab-btn.active')
        const type = activeTab?.getAttribute('data-type') || 'all'
        renderTimeline(type)
      }
    })
    .catch(e => console.error('Timeline SWR sync failed:', e))

  function escapeHtml(value: unknown) {
    return String(value ?? '').replace(/[&<>'"]/g, (character) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      "'": '&#39;',
      '"': '&quot;',
    })[character]!)
  }

  function renderTimeline(type: string) {
    const filtered = type === 'all' ? allItems : allItems.filter((item: any) => item.type === type)
    const lineEl = document.querySelector('.timeline-line')
    if (!lineEl) return

    if (filtered.length === 0) {
      lineEl.innerHTML = '<div class="empty-state"><p>校史走廊上没有对应类别的记录</p></div>'
      return
    }

    lineEl.innerHTML = filtered.map((item: any, i: number) => {
      const isMilestone = item.isMilestone ? 'milestone' : ''
      const dateStr = new Date(item.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })
      let extraHtml = ''
      
      if (item.photoUrl) {
        const fullPhoto = item.photoUrl.startsWith('http') ? item.photoUrl : `${API_BASE}${item.photoUrl}`
        extraHtml += `<img src="${escapeHtml(fullPhoto)}" alt="" loading="lazy" decoding="async" style="aspect-ratio: 4/3" class="tl-photo" />`
      }
      if (item.type === 'join' && item.slug) {
        extraHtml += `<a href="${escapeHtml(href(`/student/${item.slug}`))}" class="tl-link">查看 TA 的主页 →</a>`
      }
      
      const nodeClass = `timeline-node anim-enter ${isMilestone} type-${escapeHtml(item.type)}`
      const delay = Math.min(i * 0.05, 0.4)
      
      return `
        <div class="${nodeClass}" style="animation-delay: ${delay}s">
          <div class="tl-dot"></div>
          <div class="tl-card">
            <div class="tl-date">${dateStr}</div>
            <h3 class="tl-title">${escapeHtml(item.title)}</h3>
            ${item.description ? `<p class="tl-desc">${escapeHtml(item.description)}</p>` : ''}
            ${extraHtml}
          </div>
        </div>
      `
    }).join('')
  }

  // 绑定 Tab 点击事件
  const tabBtns = document.querySelectorAll('.timeline-tabs .tab-btn')
  tabBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      tabBtns.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')
      const type = btn.getAttribute('data-type') || 'all'
      renderTimeline(type)
    })
  })
</script>

<style is:global>
  .timeline-line { position: relative; max-width: 720px; margin: 0 auto; }
  .timeline-line::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1px;
    background: var(--color-paper-border);
    transform: translateX(-50%);
  }
  .timeline-node { position: relative; display: flex; margin-bottom: var(--spacing-xl); }
  .timeline-node:nth-child(odd) { padding-right: 50%; }
  .timeline-node:nth-child(even) { padding-left: 50%; justify-content: flex-end; }
  
  /* CSS-first 入场动画 */
  .anim-enter {
    opacity: 0;
    animation: nodeEnter 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes nodeEnter {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .anim-enter {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }

  .timeline-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-xxl);
  }

  .tab-btn {
    min-height: 36px;
    padding: 0 var(--spacing-md);
    border: 1px solid var(--color-paper-border);
    border-radius: var(--rounded-sm);
    background: var(--color-paper-card);
    color: var(--color-paper-muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out-quart);
  }

  .tab-btn.active {
    background: var(--color-paper-brown);
    border-color: var(--color-paper-brown);
    color: #fffaf2;
  }

  .tl-dot {
    position: absolute;
    left: 50%;
    top: 20px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--color-paper-brown);
    transform: translateX(-50%);
    z-index: 1;
  }
  .milestone .tl-dot { width: 20px; height: 20px; background: var(--color-accent-amber); box-shadow: 0 0 0 4px rgba(232, 165, 90, 0.2); }
  .tl-card {
    background: var(--color-paper-card);
    border: 1px solid var(--color-paper-border);
    border-radius: var(--rounded-md);
    padding: var(--spacing-lg);
    max-width: 340px;
    min-width: 0;
    transition: transform 0.3s var(--ease-out-quart);
    box-shadow: var(--shadow-paper-card);
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .tl-card:hover {
    transform: translateY(-2px);
  }
  .tl-date { font-size: var(--type-caption-size); color: var(--color-paper-muted); margin-bottom: var(--spacing-xs); }
  .tl-title { font-size: var(--type-title-sm-size); margin-bottom: var(--spacing-xs); overflow-wrap: anywhere; word-break: break-word; }
  .tl-desc {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 6;
    line-clamp: 6;
    max-height: 9.6em;
    overflow: hidden;
    font-size: var(--type-body-sm-size);
    color: var(--color-paper-muted);
    line-height: 1.6;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .tl-photo { width: 100%; border-radius: var(--rounded-sm); margin-top: var(--spacing-sm); }
  .tl-link { display: inline-block; margin-top: var(--spacing-sm); font-size: var(--type-body-sm-size); color: var(--color-paper-brown); text-decoration: none; }
  .tl-link:hover { text-decoration: underline; }
  .empty-state { text-align: center; padding: var(--spacing-xxl); color: var(--color-paper-muted); }

  @media (max-width: 768px) {
    .timeline-tabs {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .tab-btn {
      flex: 0 0 auto;
    }

    .timeline-item {
      grid-template-columns: 24px minmax(0, 1fr);
    }
    
    .timeline-line::before { left: 20px; }
    .timeline-node:nth-child(odd), .timeline-node:nth-child(even) { padding: 0 0 0 48px; }
    .tl-dot { left: 20px; }
    .tl-card { width: 100%; max-width: 100%; }
  }
</style>
