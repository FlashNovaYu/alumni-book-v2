---
import MainLayout from '../layouts/MainLayout.astro'
import ClassSpaceHub from '../components/ClassSpaceHub.vue'

const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)
---

<MainLayout>
  <div class="class-space-page page-shell fade-in-up">
    <div class="container">
      <header class="page-header">
        <p class="page-header__label">CLASS SPACE</p>
        <h1 class="display-lg">班级空间</h1>
        <p class="page-header__subtitle">汇聚班级温情，留存青春足迹</p>
      </header>
      
      <ClassSpaceHub client:load apiBase={CLIENT_API_BASE} />
    </div>
  </div>
</MainLayout>

<style>
.class-space-page {
  padding-bottom: var(--spacing-xxl);
}
</style>
