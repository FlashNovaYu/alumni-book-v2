---
import MainLayout from '../layouts/MainLayout.astro'
import ClassSpaceHub from '../components/ClassSpaceHub.vue'
import PageHeader from '../components/PageHeader.astro'

const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const CLIENT_API_BASE = import.meta.env.VITE_API_BASE_URL || (base.endsWith('/') ? base.slice(0, -1) : base)
---

<MainLayout>
  <div class="class-space-page page-shell">
    <div class="container">
      <PageHeader label="CLASS SPACE" title="班级空间" subtitle="汇聚班级温情，留存青春足迹" />
      
      <ClassSpaceHub client:load apiBase={CLIENT_API_BASE} siteBase={base} />
    </div>
  </div>
</MainLayout>

<style>
.class-space-page {
  padding-bottom: var(--spacing-xxl);
}
</style>
