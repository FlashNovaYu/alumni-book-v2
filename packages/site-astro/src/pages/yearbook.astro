---
import MainLayout from '../layouts/MainLayout.astro'
import { normalizeLegacyFileUrls } from '../../../../workers/api/src/lib/fileUrl'
import { buildMediaSources, type MediaVariant } from '@alumni/shared'

interface Classmate {
  name: string
  slug: string
  avatarUrl: string | null
  motto: string
  visitCount: number
  updatedAt: string
}

interface Photo {
  id: string
  r2Key: string
  caption: string
  media?: { variants: MediaVariant[] } | null
}

interface Album {
  id: string
  title: string
  photos: Photo[]
}

interface Message {
  id: string
  authorName: string
  content: string
  createdAt: string
  cardStyle: string
}

const API_BASE = import.meta.env.VITE_WORKER_URL || 'https://alumni-book.pages.dev'
const base = process.env.SITE_BASE || import.meta.env.BASE_URL || '/'
const href = (path: string) => `${base}${path.replace(/^\/+/, '')}`

let students: Classmate[] = []
let albums: Album[] = []
let siteConfig: any = null
let messages: Message[] = []
let timelineEvents: any[] = []

async function fetchWithRetry(url: string, retries = 4, delay = 1000): Promise<any> {
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const res = await fetch(url)
      if (!res.ok) {
        throw new Error(`HTTP ${res.status}`)
      }
      return normalizeLegacyFileUrls(await res.json())
    } catch (e: any) {
      if (attempt === retries) {
        throw e
      }
      console.warn(`yearbook.astro fetch failed (attempt ${attempt + 1}/${retries + 1}) for ${url}: ${e.message}. Retrying in ${delay}ms...`)
      await new Promise(r => setTimeout(r, delay))
      delay *= 2
    }
  }
}

try {
  const [studentsData, albumsData, configData, timelineData, msgData] = await Promise.all([
    fetchWithRetry(`${API_BASE}/api/students?audience=public`),
    fetchWithRetry(`${API_BASE}/api/albums`),
    fetchWithRetry(`${API_BASE}/api/config`),
    fetchWithRetry(`${API_BASE}/api/timeline`),
    fetchWithRetry(`${API_BASE}/api/messages/approved`),
  ])
  
  students = studentsData?.data || []
  albums = albumsData?.data || []
  siteConfig = configData?.data || {}
  timelineEvents = (timelineData?.data || []).filter((e: any) => e.isMilestone)
  messages = msgData?.data || []
} catch (e: any) {
  console.error(`❌ yearbook.astro failed to pre-fetch data: ${e.message}. Aborting build.`)
  throw e
}

// 汇总统计
const totalStudents = students.length
const totalPhotos = albums.reduce((sum, a) => sum + (a.photos?.length || 0), 0)
const totalVisits = students.reduce((sum, s) => sum + (s.visitCount || 0), 0)
const totalMessages = messages.length

// 排行
const topVisited = [...students].sort((a, b) => b.visitCount - a.visitCount).slice(0, 3)

function photoMedia(photo: Photo) {
  const source = photo.r2Key.startsWith('http') ? photo.r2Key : `${API_BASE}/api/files/${photo.r2Key}`
  const media = buildMediaSources(source, photo.media?.variants, 320, 213)
  return { src: media.src, srcset: media.srcset || undefined, sizes: media.sizes, width: media.width, height: media.height }
}
---

<MainLayout>
  <div class="yearbook-page page-shell">
    <div class="container no-print text-center py-4">
      <button class="print-btn btn-primary" onclick="window.print()"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 9V4h12v5M6 18H4V9h16v9h-2M7 14h10v6H7z" /></svg>打印此纪念册 / 导出 PDF</button>
    </div>

    <main class="yearbook-paper">
    <!-- 纪念册封面页 -->
    <div class="print-section page-break text-center">
      <div class="cover-wrapper">
        <p class="cover-tag">· CLASS YEARBOOK ·</p>
        <h1 class="cover-title">青春不散场</h1>
        <p class="cover-subtitle">班级纪念册 & 毕业年度报告</p>
        <div class="cover-deco"></div>
        <p class="cover-date">生成时间: {new Date().toLocaleDateString('zh-CN')}</p>
      </div>
    </div>

    <!-- 班级寄语 -->
    <div class="print-section page-break">
      <h2 class="section-title"><svg class="section-title-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="m5 19 3.5-.8L18 8.7 15.3 6 5.8 15.5zM14.5 6.8l2.7-2.7 2.7 2.7-2.7 2.7" /></svg>班级寄语</h2>
      <div class="preface-box card p-5 mt-4">
        <h3 class="font-display text-xl mb-3">{siteConfig?.preface?.title || '致青春岁月'}</h3>
        <h4 class="text-muted text-sm mb-4">{siteConfig?.preface?.subtitle || '写在翻开同学录之前'}</h4>
        <p class="preface-content whitespace-pre-wrap">{siteConfig?.preface?.content || '那些年，我们一起走过的日子...'}</p>
      </div>
    </div>

    <!-- 班级年度数据报告 -->
    <div class="print-section page-break">
      <h2 class="section-title"><svg class="section-title-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 19V11M11 19V5M17 19v-9" /></svg>青春数据报告</h2>
      <div class="yearbook-summary-grid mt-4">
        <div class="stat-item card">
          <span class="stat-num">{totalStudents}</span>
          <span class="stat-lbl">同窗好友</span>
        </div>
        <div class="stat-item card">
          <span class="stat-num">{totalPhotos}</span>
          <span class="stat-lbl">珍贵瞬间</span>
        </div>
        <div class="stat-item card">
          <span class="stat-num">{totalVisits}</span>
          <span class="stat-lbl">主页访问</span>
        </div>
        <div class="stat-item card">
          <span class="stat-num">{totalMessages}</span>
          <span class="stat-lbl">收到留言</span>
        </div>
      </div>
      
      <div class="rankings-box mt-5 card p-4">
        <h3 class="font-display text-lg mb-3 yearbook-subheading"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 4h10v4a5 5 0 0 1-10 0zM7 6H4v1a4 4 0 0 0 4 4M17 6h3v1a4 4 0 0 1-4 4M12 13v4M8 20h8" /></svg>班级人气王</h3>
        <div class="rank-list-vertical">
          {topVisited.map((s, idx) => (
            <div class="rank-row">
              <span class="rank-num-badge">{idx + 1}</span>
              <span class="rank-name-lbl">{s.name}</span>
              <span class="rank-val-lbl">主页被浏览了 {s.visitCount} 次</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- 同学录名录墙 -->
    <div class="print-section page-break">
      <h2 class="section-title"><svg class="section-title-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="9" cy="8" r="3" /><circle cx="17" cy="9" r="2" /><path d="M3.5 20c.6-3.4 2.4-5.2 5.5-5.2s4.9 1.8 5.5 5.2M15 15c2.8.2 4.5 1.8 5 5" /></svg>同窗好友名录</h2>
      <div class="yearbook-classmate-grid mt-4">
        {students.map(mate => {
          const motto = (mate as any).info?.motto || '这家伙很懒，什么都没留下'
          return (
            <div class="yearbook-mate-card card">
              <div class="mate-avatar-box">
                {mate.avatarUrl ? (
                  <object
                    class="mate-avatar-image"
                    data={mate.avatarUrl.startsWith('http') ? mate.avatarUrl : `${API_BASE}${mate.avatarUrl}`}
                    aria-label={`${mate.name}的头像`}
                    style="aspect-ratio: 1"
                  >
                    <span class="mate-avatar-char">{mate.name.charAt(0)}</span>
                  </object>
                ) : (
                  <span class="mate-avatar-char">{mate.name.charAt(0)}</span>
                )}
              </div>
              <h3 class="mate-name mt-2">{mate.name}</h3>
              <p class="mate-motto mt-1">“{motto}”</p>
            </div>
          )
        })}
      </div>
      <p class="text-muted text-center mt-3 no-print" style="font-size: 12px;">
        * 注：未开通专属主页或个人资料不全的同学，在此名录中将显示馆藏缺失提示。
      </p>
    </div>

    <!-- 青春瞬间（精选照片） -->
    <div class="print-section page-break">
      <h2 class="section-title"><svg class="section-title-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="5" width="16" height="14" rx="1" /><circle cx="9" cy="10" r="1.5" /><path d="m6 17 4-4 3 3 2-2 3 3" /></svg>青春瞬间</h2>
      {totalPhotos === 0 ? (
        <p class="text-muted text-center py-4">暂无照片记录，请在后台上传</p>
      ) : (
        <div class="yearbook-photo-grid mt-4">
          {albums.map(album => 
            (album.photos || []).slice(0, 3).map(photo => (
              <div class="yearbook-photo-card card">
                <div class="yearbook-photo-img-wrapper">
                  <img {...photoMedia(photo)} alt={photo.caption} loading="lazy" decoding="async" />
                </div>
                {photo.caption && <p class="yearbook-photo-caption mt-1">{photo.caption}</p>}
              </div>
            ))
          )}
        </div>
      )}
    </div>

    <!-- 时光足迹（时间轴） -->
    <div class="print-section page-break">
      <h2 class="section-title"><svg class="section-title-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="8" /><path d="M12 7v5l3 2" /></svg>时光足迹</h2>
      {timelineEvents.length === 0 ? (
        <p class="text-muted text-center py-4">暂无时光足迹记录</p>
      ) : (
        <div class="yearbook-timeline mt-4">
          {timelineEvents.map(event => (
            <div class="timeline-event card p-4 mb-3">
              <div class="timeline-event-header">
                <span class="timeline-event-date">{event.eventDate || event.date}</span>
                <span class="timeline-event-title">{event.title}</span>
              </div>
              {event.description && <p class="timeline-event-desc mt-2">{event.description}</p>}
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- 精选留言墙 -->
    <div class="print-section">
      <h2 class="section-title"><svg class="section-title-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 6h14v10H9l-4 3z" /><path d="M8 10h8M8 13h5" /></svg>寄语留言板</h2>
      <div class="yearbook-messages-list mt-4">
        {messages.map(msg => (
          <div class="yearbook-msg-card card p-4 mb-3">
            <div class="msg-card-meta">
              <span class="msg-card-author">{msg.authorName}</span>
              <span class="msg-card-time">{new Date(msg.createdAt).toLocaleDateString('zh-CN')}</span>
            </div>
            <p class="msg-card-text mt-2">{msg.content}</p>
          </div>
        ))}
        {messages.length === 0 && (
          <p class="text-muted text-center py-4">暂无审核通过的班级留言</p>
        )}
      </div>
    </div>
    </main>
  </div>
</MainLayout>

<style>
  .yearbook-page {
    padding-top: calc(var(--nav-height) + var(--spacing-xl));
    padding-bottom: 80px;
  }
  .yearbook-paper {
    width: min(960px, 100%);
    margin: 0 auto;
  }
  .print-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 24px;
    font-size: 15px;
    border-radius: 30px;
  }
  .print-btn svg, .section-title-icon, .yearbook-subheading svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }
  .section-title, .yearbook-subheading { display: flex; align-items: center; gap: 8px; }
  .print-section {
    padding: var(--spacing-xl) 0;
  }
  .cover-wrapper {
    min-height: calc(80vh - var(--nav-height));
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .cover-tag {
    font-size: 14px;
    letter-spacing: 0.2em;
    color: var(--color-muted);
  }
  .cover-title {
    font-family: var(--font-display);
    font-size: 54px;
    font-weight: 700;
    color: var(--color-primary);
    margin-top: 16px;
  }
  .cover-subtitle {
    font-size: 18px;
    color: var(--color-muted);
    margin-top: 8px;
  }
  .cover-deco {
    width: 60px;
    height: 4px;
    background: var(--color-primary);
    margin: 32px 0;
    border-radius: 2px;
  }
  .cover-date {
    font-size: 13px;
    color: var(--color-muted);
  }
  .preface-box {
    background: var(--color-surface-cream, #faf9f5);
  }
  .preface-content {
    line-height: 1.8;
    color: #4e342e;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .yearbook-summary-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
  }
  .stat-item {
    padding: 24px 16px;
    text-align: center;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    color: var(--color-primary);
    display: block;
    line-height: 1;
    margin-bottom: 8px;
  }
  .stat-lbl {
    font-size: 12px;
    color: var(--color-muted);
  }
  .rankings-box {
    background: var(--color-surface-card);
  }
  .rank-list-vertical {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .rank-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-hairline-soft);
    min-width: 0;
  }
  .rank-num-badge {
    width: 24px;
    height: 24px;
    background: var(--color-surface-cream-strong);
    color: var(--color-muted);
    border-radius: 50%;
    font-size: 12px;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rank-row:nth-child(1) .rank-num-badge { background: var(--color-gold); color: #fff; }
  .rank-row:nth-child(2) .rank-num-badge { background: var(--color-silver); color: #fff; }
  .rank-row:nth-child(3) .rank-num-badge { background: var(--color-bronze); color: #fff; }
  .rank-name-lbl {
    font-weight: 600;
    font-size: 14px;
    width: 80px;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .rank-val-lbl {
    font-size: 13px;
    color: var(--color-muted);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .yearbook-classmate-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .yearbook-mate-card {
    padding: 20px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 0;
  }
  .mate-avatar-box {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-surface-cream-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--color-hairline);
  }
  .mate-avatar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mate-avatar-char {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: var(--color-muted);
  }
  .mate-name {
    font-size: 14px;
    font-weight: 600;
    max-width: 100%;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .mate-motto {
    font-size: 11px;
    color: var(--color-muted);
    font-style: italic;
    max-width: 100%;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .yearbook-msg-card {
    background: var(--color-surface-cream, #faf9f5);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .msg-card-meta {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 12px;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-hairline-soft);
    padding-bottom: 4px;
    min-width: 0;
  }
  .msg-card-author {
    font-weight: 600;
    color: var(--color-ink);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .msg-card-time {
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .msg-card-text {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 8;
    line-clamp: 8;
    max-height: 12em;
    overflow: hidden;
    font-size: 13px;
    line-height: 1.5;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  @media screen {
    .yearbook-page {
      color: var(--color-paper-ink);
    }

    .yearbook-paper {
      padding: clamp(20px, 5vw, 56px);
      background:
        linear-gradient(90deg, rgba(143, 101, 60, 0.035) 1px, transparent 1px),
        var(--color-paper-card);
      background-size: 28px 100%, 100% 100%;
      border: 1px solid var(--color-paper-border);
      box-shadow: var(--shadow-paper-panel);
    }

    .print-section {
      width: 100%;
      margin: 0;
      padding: clamp(24px, 4vw, 40px) 0;
      border-bottom: 1px solid var(--color-paper-border);
    }
    .print-section:last-child { border-bottom: 0; }

    .section-title {
      color: var(--color-paper-ink);
      border-bottom: 1px solid var(--color-paper-border);
    }
  }

  /* 打印优化 */
  @media print {
    nav, .no-print, .print-btn {
      display: none !important;
    }
    body, html {
      background: white !important;
      color: black !important;
      font-size: 12pt !important;
    }
    .yearbook-page {
      padding-top: 0 !important;
      max-width: 100% !important;
      padding-bottom: 0 !important;
    }
    .card {
      border: 1px solid #ddd !important;
      box-shadow: none !important;
      background: white !important;
      transform: none !important;
    }
    .page-break {
      page-break-after: always !important;
      break-after: page !important;
    }
    .preface-box {
      background: #fdfdfd !important;
      border: 1px solid #ccc !important;
    }
    .yearbook-summary-grid {
      grid-template-columns: repeat(4, 1fr) !important;
    }
    .yearbook-classmate-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }

  @media (max-width: 768px) {
    .yearbook-summary-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .yearbook-classmate-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* 青春瞬间网格 */
  .yearbook-photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .yearbook-photo-card {
    padding: 10px;
    display: flex;
    flex-direction: column;
  }
  .yearbook-photo-img-wrapper {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--rounded-sm);
    background: var(--color-surface-soft);
  }
  .yearbook-photo-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal);
  }
  .yearbook-photo-card:hover .yearbook-photo-img-wrapper img {
    transform: scale(1.03);
  }
  .yearbook-photo-caption {
    font-size: 12px;
    color: var(--color-muted);
    text-align: center;
  }

  /* 时光足迹时间轴 */
  .yearbook-timeline {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    padding-left: 20px;
    border-left: 2px solid var(--color-hairline);
    margin-bottom: 24px;
  }
  .timeline-event {
    position: relative;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .timeline-event::before {
    content: '';
    position: absolute;
    left: -27px;
    top: 22px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-primary);
    border: 2px solid var(--color-canvas);
  }
  .timeline-event-header {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }
  .timeline-event-date {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-primary);
    font-size: 14px;
  }
  .timeline-event-title {
    font-weight: 600;
    font-size: 15px;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .timeline-event-desc {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.6;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  @media (max-width: 768px) {
    .yearbook-photo-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media print {
    .yearbook-photo-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
    .yearbook-timeline {
      border-left: 1px solid #ccc !important;
    }
  }
</style>
